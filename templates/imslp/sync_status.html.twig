{% extends 'base.html.twig' %}

{% block title %}{{ 'imslp.sync_title'|trans }}{% endblock %}

{% block head %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
    background: #1a1a1a;
    color: #e8e0d4;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    min-height: 100vh;
}
.wrapper {
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
}

/* ── Header ── */
.site-header { text-align: center; margin-bottom: 2.5rem; }
.site-header h1 {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    color: #f0e6c8;
    letter-spacing: .03em;
    margin-bottom: .35rem;
}
.site-header .subtitle { font-size: .85rem; color: #8a8070; }
.back-link {
    display: inline-block;
    color: #c8a96e;
    text-decoration: none;
    font-size: .85rem;
    margin-bottom: 1.8rem;
}
.back-link:hover { text-decoration: underline; }

/* ── Shared column: jobs-grid + log-panel guaranteed same width ── */
.cards-stack {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.2rem;
}

/* ── Job cards grid ── */
.jobs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
}
@media (max-width: 680px) { .jobs-grid { grid-template-columns: 1fr; } }

/* ── Job card ── */
.job-card {
    background: #252525;
    border: 1px solid #333;
    border-radius: 12px;
    padding: 1.4rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

/* card header row */
.job-card-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: .5rem;
}
.job-card-head h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    color: #f0e6c8;
}
.ps-badge {
    font-size: .66rem;
    font-weight: 600;
    padding: .2rem .6rem;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: .05em;
    white-space: nowrap;
}
.ps-badge.running {
    background: rgba(100, 200, 120, .12);
    color: #6ec87a;
    border: 1px solid rgba(110, 200, 122, .3);
}
.ps-badge.idle {
    background: rgba(80, 80, 80, .2);
    color: #6a6058;
    border: 1px solid #333;
}

/* overview: big number */
.job-overview {
    display: flex;
    align-items: baseline;
    gap: .55rem;
}
.job-count {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    color: #f0e6c8;
    line-height: 1.1;
}
.job-count-label {
    font-size: .78rem;
    color: #8a8070;
    text-transform: uppercase;
    letter-spacing: .06em;
}

/* divider */
.job-divider {
    border: none;
    border-top: 1px solid #2e2e2e;
    margin: 0;
}

/* detail / progress section */
.progress-label-row {
    display: flex;
    justify-content: space-between;
    font-size: .8rem;
    color: #a09080;
    margin-bottom: .45rem;
}
.progress-label-row .pct { color: #c8a96e; font-weight: 600; }
.progress-bar-track {
    background: #333;
    border-radius: 999px;
    height: 8px;
    overflow: hidden;
    margin-bottom: .55rem;
}
.progress-bar-fill {
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, #c8a96e 0%, #e8c87a 100%);
    transition: width .5s ease;
}
.progress-bar-fill.animated {
    background: linear-gradient(90deg, #6ec87a 0%, #9edba8 100%);
    animation: shimmer 2s linear infinite;
    background-size: 200% 100%;
}
@keyframes shimmer {
    0%   { background-position: -200% center; }
    100% { background-position:  200% center; }
}
.remaining {
    font-size: .78rem;
    color: #8a8070;
    text-align: right;
}

/* last-sync timestamp */
.job-last-sync {
    font-size: .72rem;
    color: #5a5050;
    display: flex;
    align-items: center;
    gap: .35rem;
    margin-top: -.3rem;
}
.job-last-sync svg { flex-shrink: 0; opacity: .5; }

/* description text */
.job-desc {
    font-size: .78rem;
    color: #6a6058;
    text-align: center;
}

/* action footer */
.job-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: .4rem;
    margin-top: auto;
}
.job-footer-right {
    display: flex;
    align-items: center;
    gap: .4rem;
}

/* Buttons */
.btn-card {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    background: linear-gradient(135deg, #c8a96e 0%, #e8c87a 100%);
    color: #1a1a1a;
    border: none;
    padding: .45rem 1.1rem;
    border-radius: 6px;
    font-size: .8rem;
    font-weight: 700;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    letter-spacing: .03em;
    transition: opacity .15s, transform .1s;
    white-space: nowrap;
}
.btn-card:hover  { opacity: .9; }
.btn-card:active { transform: scale(.97); }
.btn-card:disabled { opacity: .4; cursor: not-allowed; }
.btn-card svg { width: 12px; height: 12px; flex-shrink: 0; }

.btn-stop {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    background: none;
    border: 1px solid #7a3030;
    color: #c87a7a;
    padding: .3rem .75rem;
    border-radius: 5px;
    font-size: .72rem;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    letter-spacing: .04em;
    transition: background .15s, border-color .15s, color .15s;
    white-space: nowrap;
}
.btn-stop:hover { background: rgba(200,80,80,.12); border-color: #c87a7a; }
.btn-stop:active { transform: scale(.97); }
.btn-stop svg { width: 10px; height: 10px; flex-shrink: 0; }

.btn-log {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: .35rem;
    background: none;
    border: 1px solid #3a3a3a;
    color: #8a8070;
    padding: .3rem .75rem;
    border-radius: 5px;
    font-size: .72rem;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    letter-spacing: .04em;
    transition: border-color .15s, color .15s;
    white-space: nowrap;
    min-width: 5.5rem;
}
.btn-log:hover   { border-color: #c8a96e; color: #c8a96e; }
.btn-log.active  { border-color: #c8a96e; color: #c8a96e; background: rgba(200,169,110,.07); }

/* ── System gauges ── */
.gauges-row {
    display: flex;
    justify-content: center;
    gap: 2.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
}
.gauge-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .55rem;
}
.gauge-svg { display: block; }
.gauge-arc-bg  { fill: none; stroke: #2e2e2e; stroke-width: 10; }
.gauge-arc-fill { fill: none; stroke-width: 10; stroke-linecap: round;
                  transition: stroke-dashoffset .6s ease, stroke .4s; }
.gauge-label {
    font-size: .72rem;
    text-transform: uppercase;
    letter-spacing: .07em;
    color: #6a6058;
    font-weight: 600;
}
.gauge-detail {
    font-size: .7rem;
    color: #5a5050;
    text-align: center;
    min-height: 1rem;
}

/* ── Full-width log panel ── */
.log-panel {
    background: #1e1e1e;
    border: 1px solid #333;
    border-radius: 10px;
    overflow: hidden;
    display: none;
}
.log-panel.visible { display: block; }
.log-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: .65rem 1.2rem;
    background: #252525;
    border-bottom: 1px solid #2e2e2e;
}
.log-panel-title {
    font-size: .73rem;
    text-transform: uppercase;
    letter-spacing: .07em;
    color: #c8a96e;
    font-weight: 600;
}
.btn-log-close {
    background: none;
    border: none;
    color: #5a5050;
    cursor: pointer;
    font-size: 1rem;
    line-height: 1;
    padding: 0 .2rem;
    transition: color .15s;
}
.btn-log-close:hover { color: #c8a96e; }
.log-box {
    background: #111;
    padding: 1rem 1.2rem;
    font-family: 'Courier New', monospace;
    font-size: .8rem;
    color: #7a9a7a;
    height: 320px;
    overflow-y: auto;
    white-space: pre-wrap;
    word-break: break-all;
}
</style>
{% endblock %}

{% block body %}
<div class="wrapper">

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.8rem;">
        <a href="{{ path('app_imslp') }}" class="back-link" style="margin-bottom:0;">{{ 'imslp.sync_back_to_browser'|trans }}</a>
        <a href="/pma/" target="_blank" rel="noopener"
           style="display:inline-flex;align-items:center;gap:.4rem;background:none;border:1px solid #3a3a3a;color:#8a8070;padding:.3rem .85rem;border-radius:5px;font-size:.78rem;text-decoration:none;letter-spacing:.03em;transition:border-color .15s,color .15s;"
           onmouseover="this.style.borderColor='#c8a96e';this.style.color='#c8a96e';"
           onmouseout="this.style.borderColor='#3a3a3a';this.style.color='#8a8070';">
            <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor">
                <path d="M1 3.5A1.5 1.5 0 0 1 2.5 2h11A1.5 1.5 0 0 1 15 3.5v9A1.5 1.5 0 0 1 13.5 14h-11A1.5 1.5 0 0 1 1 12.5v-9zm2 1v7h10v-7H3zm0-1h10V3.5a.5.5 0 0 0-.5-.5h-9a.5.5 0 0 0-.5.5V3.5z"/>
            </svg>
            {{ 'imslp.sync_phpmyadmin'|trans }}
        </a>
    </div>

    <header class="site-header">
        <h1>{{ 'imslp.sync_title'|trans }}</h1>
        <p class="subtitle">{{ 'imslp.sync_subtitle'|trans }}</p>
    </header>

    {% if running or syncRunning or datesRunning or composersRunning %}
    <p style="font-size:.82rem;color:#6a6058;margin-bottom:1.5rem;text-align:center;">{{ 'imslp.sync_auto_refresh'|trans }}</p>
    {% endif %}

    <!-- System gauges -->
    <div class="gauges-row" id="gauges-row">
        {% for id, label in {cpu: 'CPU', mem: 'Memory', disk: 'Disk'} %}
        <div class="gauge-wrap">
            <svg class="gauge-svg" width="96" height="96" viewBox="0 0 96 96">
                <circle class="gauge-arc-bg"  cx="48" cy="48" r="38"
                        stroke-dasharray="215 999"
                        stroke-dashoffset="-54"
                        transform="rotate(-210 48 48)"/>
                <circle class="gauge-arc-fill" id="gauge-fill-{{ id }}" cx="48" cy="48" r="38"
                        stroke-dasharray="0 239"
                        stroke-dashoffset="0"
                        transform="rotate(-210 48 48)"
                        stroke="#c8a96e"/>
                <text x="48" y="46" text-anchor="middle"
                      font-family="'Playfair Display', serif"
                      font-size="17" fill="#f0e6c8" id="gauge-pct-{{ id }}">—</text>
                <text x="48" y="60" text-anchor="middle"
                      font-family="'Inter', sans-serif"
                      font-size="8" fill="#6a6058" letter-spacing=".04em">{{ label|upper }}</text>
            </svg>
            <span class="gauge-detail" id="gauge-detail-{{ id }}"></span>
        </div>
        {% endfor %}
    </div>

    <!-- Job cards + log panel in a shared column so widths are identical -->
    <div class="cards-stack">
    <div class="jobs-grid">

        <!-- Composers card -->
        <div class="job-card">
            <div class="job-card-head">
                <h2>{{ 'imslp.sync_card_composers'|trans }}</h2>
                <div style="display:flex;align-items:center;gap:.4rem;">
                    <span class="ps-badge {% if composersRunning or datesRunning %}running{% else %}idle{% endif %}">
                        {% if composersRunning or datesRunning %}{{ 'imslp.sync_badge_running'|trans }}{% else %}{{ 'imslp.sync_badge_idle'|trans }}{% endif %}
                    </span>
                    {% if composersRunning %}
                    <button class="btn-stop" data-stop-url="{{ path('app_imslp_sync_composers_stop') }}">
                        <svg viewBox="0 0 16 16" fill="currentColor"><rect x="3" y="3" width="10" height="10"/></svg>{{ 'imslp.sync_btn_stop'|trans }}
                    </button>
                    {% endif %}
                    {% if datesRunning %}
                    <button class="btn-stop" data-stop-url="{{ path('app_imslp_sync_dates_stop') }}">
                        <svg viewBox="0 0 16 16" fill="currentColor"><rect x="3" y="3" width="10" height="10"/></svg>{{ 'imslp.sync_btn_stop'|trans }}
                    </button>
                    {% endif %}
                </div>
            </div>

            <div class="job-overview">
                <span class="job-count">{{ composers|number_format(0, '.', ' ') }}</span>
                <span class="job-count-label">{{ 'imslp.sync_in_catalogue'|trans }}</span>
            </div>
            {% if lastComposerSync %}
            <p class="job-last-sync">
                <svg width="11" height="11" viewBox="0 0 16 16" fill="#8a8070"><path d="M8 1.5A6.5 6.5 0 1 0 14.5 8 6.507 6.507 0 0 0 8 1.5ZM0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8.75-4.75v4.31l2.72 2.72-1.06 1.06-3-3A.75.75 0 0 1 7.25 7.5V3.25h1.5z"/></svg>
                {{ 'imslp.sync_last_sync_list'|trans }} {{ lastComposerSync }}{% if lastDatesSync %} &middot; {{ 'imslp.sync_last_sync_dates'|trans }} {{ lastDatesSync }}{% endif %}
            </p>
            {% endif %}

            <hr class="job-divider">

            {% set composersWithoutDates = composers - composersWithDates %}
            <div class="progress-label-row">
                <span>{{ composersWithDates|number_format }} {{ 'imslp.sync_composers_with_dates'|trans }}</span>
                <span class="pct">{{ datesPercent }}%</span>
            </div>
            <div class="progress-bar-track">
                <div class="progress-bar-fill{% if datesRunning %} animated{% endif %}"
                     style="width: {{ datesPercent }}%"></div>
            </div>
            {% if composersWithoutDates > 0 %}
                <p class="remaining">{{ composersWithoutDates|number_format }} {{ 'imslp.sync_composers_without_dates'|trans }}</p>
            {% else %}
                <p class="remaining" style="color:#6ec87a;">{{ 'imslp.sync_all_dates_fetched'|trans }}</p>
            {% endif %}

            <div class="job-footer">
                <div style="display:flex;flex-direction:column;gap:.3rem;width:100%;">
                    <form id="composers-form" action="{{ path('app_imslp_sync_composers_start') }}" method="post" style="width:100%;">
                        <button type="submit" class="btn-card" id="composers-btn"{% if composersRunning %} disabled{% endif %} style="width:100%;justify-content:center;">
                            <svg viewBox="0 0 16 16" fill="currentColor"><path d="M3 2.5l10 5.5-10 5.5V2.5z"/></svg>
                            {% if composersRunning %}{{ 'imslp.sync_btn_syncing'|trans }}{% else %}{{ 'imslp.sync_btn_sync_list'|trans }}{% endif %}
                        </button>
                    </form>
                    <form id="dates-form" action="{{ path('app_imslp_sync_dates_start') }}" method="post" style="width:100%;">
                        <button type="submit" class="btn-card" id="dates-btn"{% if datesRunning %} disabled{% endif %}
                                style="background:linear-gradient(135deg,#8a7050 0%,#b09060 100%);width:100%;justify-content:center;">
                            <svg viewBox="0 0 16 16" fill="currentColor"><path d="M3 2.5l10 5.5-10 5.5V2.5z"/></svg>
                            {% if datesRunning %}{{ 'imslp.sync_btn_fetching'|trans }}{% else %}{{ 'imslp.sync_btn_sync_dates'|trans }}{% endif %}
                        </button>
                    </form>
                </div>
                <div class="job-footer-right">
                    <div style="display:flex;flex-direction:column;gap:.3rem;">
                        <button class="btn-log" data-log="composers" data-label="{{ 'imslp.sync_card_composers'|trans }}">{{ 'imslp.sync_log_list'|trans }}</button>
                        <button class="btn-log" data-log="dates" data-label="{{ 'imslp.sync_btn_sync_dates'|trans }}">{{ 'imslp.sync_log_dates'|trans }}</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Works card -->
        <div class="job-card">
            <div class="job-card-head">
                <h2>{{ 'imslp.sync_card_works'|trans }}</h2>
                <div style="display:flex;align-items:center;gap:.4rem;">
                    <span class="ps-badge {% if syncRunning %}running{% else %}idle{% endif %}">
                        {% if syncRunning %}{{ 'imslp.sync_badge_running'|trans }}{% else %}{{ 'imslp.sync_badge_idle'|trans }}{% endif %}
                    </span>
                    {% if syncRunning %}
                    <button class="btn-stop" data-stop-url="{{ path('app_imslp_sync_works_stop') }}">
                        <svg viewBox="0 0 16 16" fill="currentColor"><rect x="3" y="3" width="10" height="10"/></svg>{{ 'imslp.sync_btn_stop'|trans }}
                    </button>
                    {% endif %}
                </div>
            </div>

            <div class="job-overview">
                <span class="job-count">{{ works|number_format(0, '.', ' ') }}</span>
                <span class="job-count-label">{{ 'imslp.sync_in_catalogue'|trans }}</span>
            </div>
            {% if lastWorkSync %}
            <p class="job-last-sync">
                <svg width="11" height="11" viewBox="0 0 16 16" fill="#8a8070"><path d="M8 1.5A6.5 6.5 0 1 0 14.5 8 6.507 6.507 0 0 0 8 1.5ZM0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8.75-4.75v4.31l2.72 2.72-1.06 1.06-3-3A.75.75 0 0 1 7.25 7.5V3.25h1.5z"/></svg>
                {{ 'imslp.sync_last_sync'|trans }} {{ lastWorkSync }}
            </p>
            {% endif %}

            <hr class="job-divider">

            {% if syncRunning %}
            <p class="job-desc">{{ 'imslp.sync_fetching_works'|trans }}</p>
            {% else %}
            <p class="job-desc">
                {% if works > 0 %}{{ 'imslp.sync_ready_resumes'|trans }}{% else %}{{ 'imslp.sync_not_yet_run'|trans }}{% endif %}
            </p>
            {% endif %}

            <div class="job-footer">
                <form id="sync-form" action="{{ path('app_imslp_sync_works_start') }}" method="post" style="flex:1;">
                    <button type="submit" class="btn-card" id="sync-btn"{% if syncRunning %} disabled{% endif %} style="width:100%;justify-content:center;">
                        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M3 2.5l10 5.5-10 5.5V2.5z"/></svg>
                        {% if syncRunning %}{{ 'imslp.sync_btn_syncing'|trans }}{% else %}{{ 'imslp.sync_btn_import_works'|trans }}{% endif %}
                    </button>
                </form>
                <div class="job-footer-right">
                    <button class="btn-log" data-log="sync" data-label="{{ 'imslp.sync_card_works'|trans }}">{{ 'imslp.sync_log_works'|trans }}</button>
                </div>
            </div>
        </div>

        <!-- Details card -->
        <div class="job-card">
            <div class="job-card-head">
                <h2>{{ 'imslp.sync_card_details'|trans }}</h2>
                <div style="display:flex;align-items:center;gap:.4rem;">
                    <span class="ps-badge {% if running %}running{% else %}idle{% endif %}">
                        {% if running %}{{ 'imslp.sync_badge_running'|trans }}{% else %}{{ 'imslp.sync_badge_idle'|trans }}{% endif %}
                    </span>
                    {% if running %}
                    <button class="btn-stop" data-stop-url="{{ path('app_imslp_fetch_stop') }}">
                        <svg viewBox="0 0 16 16" fill="currentColor"><rect x="3" y="3" width="10" height="10"/></svg>{{ 'imslp.sync_btn_stop'|trans }}
                    </button>
                    {% endif %}
                </div>
            </div>

            <div class="job-overview">
                <span class="job-count">{{ worksWithDetail|number_format(0, '.', ' ') }}</span>
                <span class="job-count-label">{{ 'imslp.sync_with_details'|trans }}</span>
            </div>
            {% if lastDetailSync %}
            <p class="job-last-sync">
                <svg width="11" height="11" viewBox="0 0 16 16" fill="#8a8070"><path d="M8 1.5A6.5 6.5 0 1 0 14.5 8 6.507 6.507 0 0 0 8 1.5ZM0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8.75-4.75v4.31l2.72 2.72-1.06 1.06-3-3A.75.75 0 0 1 7.25 7.5V3.25h1.5z"/></svg>
                {{ 'imslp.sync_last_sync'|trans }} {{ lastDetailSync }}
            </p>
            {% endif %}

            <hr class="job-divider">

            <div class="progress-label-row">
                <span>{{ worksWithDetail|number_format }} {{ 'imslp.sync_of'|trans }} {{ works|number_format }}</span>
                <span class="pct">{{ detailPercent }}%</span>
            </div>
            <div class="progress-bar-track">
                <div class="progress-bar-fill{% if running %} animated{% endif %}"
                     style="width: {{ detailPercent }}%"></div>
            </div>
            {% if worksWithoutDetail > 0 %}
                <p class="remaining">{{ worksWithoutDetail|number_format }} {{ 'imslp.sync_works_remaining'|trans }}</p>
            {% else %}
                <p class="remaining" style="color:#6ec87a;">{{ 'imslp.sync_all_works_fetched'|trans }}</p>
            {% endif %}

            <div class="job-footer">
                <div style="display:flex;flex-direction:column;gap:.3rem;flex:1;">
                    {% if worksWithoutDetail > 0 %}
                    <form id="start-form" action="{{ path('app_imslp_fetch_start') }}" method="post" style="width:100%;">
                        <button type="submit" class="btn-card" id="start-btn"{% if running %} disabled{% endif %} style="width:100%;justify-content:center;">
                            <svg viewBox="0 0 16 16" fill="currentColor"><path d="M3 2.5l10 5.5-10 5.5V2.5z"/></svg>
                            {% if running %}{{ 'imslp.sync_btn_fetching'|trans }}{% else %}{{ 'imslp.sync_btn_fetch_details'|trans }}{% endif %}
                        </button>
                    </form>
                    {% else %}
                    <span style="font-size:.78rem;color:#6ec87a;">{{ 'imslp.sync_btn_complete'|trans }}</span>
                    {% endif %}
                    <form id="fill-all-form" action="{{ path('app_imslp_fetch_start') }}" method="post" style="width:100%;">
                        <input type="hidden" name="mode" value="fill-all">
                        <button type="submit" class="btn-card" id="fill-all-btn"{% if running %} disabled{% endif %}
                                style="background:linear-gradient(135deg,#507050 0%,#709060 100%);width:100%;justify-content:center;">
                            <svg viewBox="0 0 16 16" fill="currentColor"><path d="M3 2.5l10 5.5-10 5.5V2.5z"/></svg>
                            {% if running %}{{ 'imslp.sync_btn_fetching'|trans }}{% else %}{{ 'imslp.sync_btn_fill_missing'|trans }}{% endif %}
                        </button>
                    </form>
                </div>
                <div class="job-footer-right">
                    <button class="btn-log" data-log="fetch" data-label="{{ 'imslp.sync_card_details'|trans }}">{{ 'imslp.sync_log_details'|trans }}</button>
                </div>
            </div>
        </div>

    </div>

    <!-- Shared log panel (same column as jobs-grid) -->
    <div class="log-panel" id="log-panel">
        <div class="log-panel-header">
            <span class="log-panel-title" id="log-panel-title">{{ 'imslp.sync_log_title'|trans }}</span>
            <button class="btn-log-close" id="log-panel-close" title="Close">✕</button>
        </div>
        <div class="log-box" id="log-panel-box"></div>
    </div>

    </div>{# end .cards-stack #}

</div>

<script>
(function () {
    const fetchRunning     = {{ running ? 'true' : 'false' }};
    const syncRunning      = {{ syncRunning ? 'true' : 'false' }};
    const datesRunning     = {{ datesRunning ? 'true' : 'false' }};
    const composersRunning = {{ composersRunning ? 'true' : 'false' }};

    const LOG_URLS = {
        sync:      '{{ path('app_imslp_sync_log') }}',
        fetch:     '{{ path('app_imslp_fetch_log') }}',
        dates:     '{{ path('app_imslp_dates_log') }}',
        composers: '{{ path('app_imslp_composers_log') }}',
    };

    // ── Shared log panel ──────────────────────────────────────────────────────
    const panel    = document.getElementById('log-panel');
    const panelBox = document.getElementById('log-panel-box');
    const panelTitle = document.getElementById('log-panel-title');
    let activeLog  = null;
    let pollTimer  = null;

    const SYNC_TRANS = {
        logTitle:     {{ 'imslp.sync_log_title'|trans|json_encode|raw }},
        logLoading:   {{ 'imslp.sync_log_loading'|trans|json_encode|raw }},
        logNoOutput:  {{ 'imslp.sync_log_no_output'|trans|json_encode|raw }},
        logUnavail:   {{ 'imslp.sync_log_unavailable'|trans|json_encode|raw }},
        stopping:     {{ 'imslp.sync_btn_stopping'|trans|json_encode|raw }},
        starting:     {{ 'imslp.sync_btn_starting'|trans|json_encode|raw }},
        fetchDetails: {{ 'imslp.sync_btn_fetch_details'|trans|json_encode|raw }},
        fillMissing:  {{ 'imslp.sync_btn_fill_missing'|trans|json_encode|raw }},
        importWorks:  {{ 'imslp.sync_btn_import_works'|trans|json_encode|raw }},
        syncDates:    {{ 'imslp.sync_btn_sync_dates'|trans|json_encode|raw }},
        syncList:     {{ 'imslp.sync_btn_sync_list'|trans|json_encode|raw }},
        syncing:      {{ 'imslp.sync_btn_syncing'|trans|json_encode|raw }},
        fetching:     {{ 'imslp.sync_btn_fetching'|trans|json_encode|raw }},
    };

    function loadLog(key) {
        const url = LOG_URLS[key];
        if (!url) return;
        fetch(url)
            .then(r => r.ok ? r.text() : Promise.reject())
            .then(txt => {
                panelBox.textContent = txt || SYNC_TRANS.logNoOutput;
                panelBox.scrollTop = panelBox.scrollHeight;
            })
            .catch(() => { panelBox.textContent = SYNC_TRANS.logUnavail; });
    }

    function showLog(key, label) {
        if (activeLog === key && panel.classList.contains('visible')) return;

        document.querySelectorAll('.btn-log').forEach(b => {
            b.classList.toggle('active', b.dataset.log === key);
        });

        activeLog = key;
        panelTitle.textContent = SYNC_TRANS.logTitle + ' — ' + label;
        panelBox.textContent = SYNC_TRANS.logLoading;
        panel.classList.add('visible');
        panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

        loadLog(key);

        clearInterval(pollTimer);
        pollTimer = setInterval(() => { if (activeLog) loadLog(activeLog); }, 5000);
    }

    function closePanel() {
        panel.classList.remove('visible');
        document.querySelectorAll('.btn-log').forEach(b => b.classList.remove('active'));
        activeLog = null;
        clearInterval(pollTimer);
    }

    document.querySelectorAll('.btn-log').forEach(btn => {
        btn.addEventListener('click', () => showLog(btn.dataset.log, btn.dataset.label));
    });

    document.getElementById('log-panel-close').addEventListener('click', closePanel);

    // ── Auto-open log for the running job (if any)
    if (datesRunning)          showLog('dates',     {{ 'imslp.sync_btn_sync_dates'|trans|json_encode|raw }});
    else if (syncRunning)      showLog('sync',      {{ 'imslp.sync_card_works'|trans|json_encode|raw }});
    else if (fetchRunning)     showLog('fetch',     {{ 'imslp.sync_card_details'|trans|json_encode|raw }});
    else if (composersRunning) showLog('composers', {{ 'imslp.sync_card_composers'|trans|json_encode|raw }});

    // ── Wire action buttons ───────────────────────────────────────────────────
    function wireForm(formId, btnId, startLabel, runningLabel) {
        const form = document.getElementById(formId);
        if (!form) return;
        form.addEventListener('submit', function (e) {
            e.preventDefault();
            const btn = document.getElementById(btnId);
            btn.disabled = true;
            btn.textContent = SYNC_TRANS.starting;
            fetch(form.action, { method: 'POST' })
                .then(r => r.json())
                .then(data => {
                    if (data.started) {
                        btn.textContent = runningLabel;
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        btn.disabled = false;
                        btn.textContent = startLabel;
                        alert('Could not start: ' + (data.message || 'unknown error'));
                    }
                })
                .catch(() => location.reload());
        });
    }

    wireForm('start-form',     'start-btn',     SYNC_TRANS.fetchDetails,  SYNC_TRANS.fetching);
    wireForm('fill-all-form',  'fill-all-btn',  SYNC_TRANS.fillMissing,   SYNC_TRANS.fetching);
    wireForm('sync-form',      'sync-btn',      SYNC_TRANS.importWorks,   SYNC_TRANS.syncing);
    wireForm('dates-form',     'dates-btn',     SYNC_TRANS.syncDates,     SYNC_TRANS.fetching);
    wireForm('composers-form', 'composers-btn', SYNC_TRANS.syncList,      SYNC_TRANS.syncing);

    // ── Wire stop buttons ─────────────────────────────────────────────────────
    document.querySelectorAll('.btn-stop').forEach(btn => {
        btn.addEventListener('click', function () {
            btn.disabled = true;
            btn.textContent = SYNC_TRANS.stopping;
            fetch(btn.dataset.stopUrl, { method: 'POST' })
                .then(r => r.json())
                .then(() => setTimeout(() => location.reload(), 800))
                .catch(() => location.reload());
        });
    });

    // Auto-reload while any job is running
    if (fetchRunning || syncRunning || datesRunning || composersRunning) {
        setTimeout(() => location.reload(), 10000);
    }

    // ── System gauges ─────────────────────────────────────────────────────────
    const STATS_URL = '{{ path('app_imslp_system_stats') }}';
    // Arc parameters: radius=38, arc spans 240° (from -210° to 30°)
    const R       = 38;
    const ARC_DEG = 240;
    const CIRCUM  = 2 * Math.PI * R;         // full circle circumference
    const ARC_LEN = (ARC_DEG / 360) * CIRCUM; // length of the 240° arc

    const GAUGE_COLOR = {
        low:  '#6ec87a',   // green  < 60 %
        mid:  '#c8a96e',   // amber  60–85 %
        high: '#c87a7a',   // red    > 85 %
    };

    function gaugeColor(pct) {
        return pct > 85 ? GAUGE_COLOR.high : pct > 60 ? GAUGE_COLOR.mid : GAUGE_COLOR.low;
    }

    function setGauge(id, pct, detail) {
        const fill   = document.getElementById('gauge-fill-' + id);
        const label  = document.getElementById('gauge-pct-'  + id);
        const detEl  = document.getElementById('gauge-detail-' + id);
        if (!fill) return;

        const filled = (pct / 100) * ARC_LEN;
        fill.setAttribute('stroke-dasharray', filled + ' ' + CIRCUM);
        fill.setAttribute('stroke', gaugeColor(pct));
        label.textContent = pct + '%';
        if (detEl && detail) detEl.textContent = detail;
    }

    function loadStats() {
        fetch(STATS_URL)
            .then(r => r.ok ? r.json() : Promise.reject())
            .then(d => {
                setGauge('cpu',  d.cpu.pct,  '');
                setGauge('mem',  d.mem.pct,  d.mem.used  + ' / ' + d.mem.total);
                setGauge('disk', d.disk.pct, d.disk.used + ' / ' + d.disk.total);
            })
            .catch(() => {});
    }

    loadStats();
    setInterval(loadStats, 3000);
})();
</script>
{% endblock %}
