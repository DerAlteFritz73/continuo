{% extends 'base.html.twig' %}

{% block title %}IMSLP Import Status{% endblock %}

{% block head %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
    background: #1a1a1a;
    color: #e8e0d4;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    min-height: 100vh;
}
.wrapper {
    max-width: 780px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
}

/* ── Header ── */
.site-header { text-align: center; margin-bottom: 2.5rem; }
.site-header h1 {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    color: #f0e6c8;
    letter-spacing: .03em;
    margin-bottom: .35rem;
}
.site-header .subtitle { font-size: .85rem; color: #8a8070; }
.back-link {
    display: inline-block;
    color: #c8a96e;
    text-decoration: none;
    font-size: .85rem;
    margin-bottom: 1.8rem;
}
.back-link:hover { text-decoration: underline; }

/* ── Status badge ── */
.status-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: .75rem;
}
.status-badge {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    font-size: .85rem;
    font-weight: 600;
    padding: .4rem .9rem;
    border-radius: 999px;
    letter-spacing: .04em;
    text-transform: uppercase;
}
.status-badge.running {
    background: rgba(100, 200, 120, .12);
    color: #6ec87a;
    border: 1px solid rgba(110, 200, 122, .3);
}
.status-badge.idle {
    background: rgba(200, 169, 110, .1);
    color: #c8a96e;
    border: 1px solid rgba(200, 169, 110, .25);
}
.pulse {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #6ec87a;
    animation: pulse 1.4s ease-in-out infinite;
}
.dot-idle {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #c8a96e;
    opacity: .6;
}
@keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: .4; transform: scale(.7); }
}

/* ── Stat cards ── */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
}
@media (max-width: 560px) { .stats-grid { grid-template-columns: 1fr; } }

.stat-card {
    background: #252525;
    border: 1px solid #333;
    border-radius: 10px;
    padding: 1.2rem 1.4rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: .8rem;
}
.stat-card .value {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    color: #f0e6c8;
    line-height: 1.1;
    margin-bottom: .2rem;
}
.stat-card .label {
    font-size: .78rem;
    color: #8a8070;
    text-transform: uppercase;
    letter-spacing: .06em;
}
.stat-card .card-action {
    border-top: 1px solid #2e2e2e;
    padding-top: .7rem;
    margin-top: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .45rem;
}
.btn-card {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    background: linear-gradient(135deg, #c8a96e 0%, #e8c87a 100%);
    color: #1a1a1a;
    border: none;
    padding: .45rem 1.1rem;
    border-radius: 6px;
    font-size: .8rem;
    font-weight: 700;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    letter-spacing: .03em;
    transition: opacity .15s, transform .1s;
    white-space: nowrap;
}
.btn-card:hover  { opacity: .9; }
.btn-card:active { transform: scale(.97); }
.btn-card:disabled { opacity: .4; cursor: not-allowed; }
.btn-card svg { width: 12px; height: 12px; flex-shrink: 0; }
.card-status { font-size: .72rem; color: #6a6058; min-height: 1em; }
.card-status.running { color: #6ec87a; }

/* ── Progress cards ── */
.progress-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 2rem;
}
@media (max-width: 560px) { .progress-grid { grid-template-columns: 1fr; } }

.progress-card {
    background: #252525;
    border: 1px solid #333;
    border-radius: 10px;
    padding: 1.4rem 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
}
.progress-card-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: .5rem;
}
.progress-card-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.05rem;
    color: #f0e6c8;
}
.ps-badge {
    font-size: .68rem;
    font-weight: 600;
    padding: .2rem .6rem;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: .05em;
    white-space: nowrap;
}
.ps-badge.running {
    background: rgba(100, 200, 120, .12);
    color: #6ec87a;
    border: 1px solid rgba(110, 200, 122, .3);
}
.ps-badge.idle {
    background: rgba(80, 80, 80, .2);
    color: #6a6058;
    border: 1px solid #333;
}
.ps-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .1rem;
}
.ps-number {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    color: #f0e6c8;
    line-height: 1.1;
}
.ps-sublabel {
    font-size: .73rem;
    color: #8a8070;
    text-transform: uppercase;
    letter-spacing: .05em;
}
.progress-label-row {
    display: flex;
    justify-content: space-between;
    font-size: .8rem;
    color: #a09080;
    margin-bottom: .45rem;
}
.progress-label-row .pct { color: #c8a96e; font-weight: 600; }
.progress-bar-track {
    background: #333;
    border-radius: 999px;
    height: 8px;
    overflow: hidden;
    margin-bottom: .9rem;
}
.progress-bar-fill {
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, #c8a96e 0%, #e8c87a 100%);
    transition: width .5s ease;
}
.progress-bar-fill.animated {
    background: linear-gradient(90deg, #6ec87a 0%, #9edba8 100%);
    animation: shimmer 2s linear infinite;
    background-size: 200% 100%;
}
@keyframes shimmer {
    0%   { background-position: -200% center; }
    100% { background-position:  200% center; }
}
.remaining {
    font-size: .78rem;
    color: #8a8070;
    text-align: right;
    margin-top: -.6rem;
}

/* ── Collapsible log ── */
.log-details {
    margin-top: auto;
    border-top: 1px solid #2a2a2a;
    padding-top: .7rem;
}
.log-details summary {
    cursor: pointer;
    font-size: .73rem;
    text-transform: uppercase;
    letter-spacing: .07em;
    color: #6a6058;
    list-style: none;
    display: flex;
    align-items: center;
    gap: .4rem;
    user-select: none;
}
.log-details summary::-webkit-details-marker { display: none; }
.log-details summary::before {
    content: '▶';
    font-size: .6rem;
    transition: transform .2s;
}
.log-details[open] summary::before { transform: rotate(90deg); }
.log-details summary:hover { color: #9a8a78; }
.log-box {
    background: #111;
    border: 1px solid #2a2a2a;
    border-radius: 8px;
    padding: .8rem 1rem;
    font-family: 'Courier New', monospace;
    font-size: .75rem;
    color: #7a9a7a;
    max-height: 180px;
    overflow-y: auto;
    white-space: pre-wrap;
    word-break: break-all;
    margin-top: .6rem;
}
</style>
{% endblock %}

{% block body %}
<div class="wrapper">

    <a href="{{ path('app_imslp') }}" class="back-link">← Back to IMSLP Browser</a>

    <header class="site-header">
        <h1>Import Status</h1>
        <p class="subtitle">IMSLP sync &amp; detail fetch progress</p>
    </header>

    <div class="status-row">
        {% if running or syncRunning %}
            <span class="status-badge running">
                <span class="pulse"></span>
                Running
            </span>
            <span style="font-size:.82rem;color:#6a6058;">Auto-refreshing every 10 s</span>
        {% else %}
            <span class="status-badge idle">
                <span class="dot-idle"></span>
                Idle
            </span>
        {% endif %}
    </div>

    <!-- Stat cards -->
    <div class="stats-grid">
        <div class="stat-card">
            <div>
                <div class="value">{{ composers|number_format(0, '.', ' ') }}</div>
                <div class="label">Composers</div>
            </div>
        </div>

        <div class="stat-card">
            <div>
                <div class="value">{{ works|number_format(0, '.', ' ') }}</div>
                <div class="label">Works total</div>
            </div>
            <div class="card-action">
                <form id="sync-form" action="{{ path('app_imslp_sync_works_start') }}" method="post">
                    <button type="submit" class="btn-card" id="sync-btn"{% if syncRunning %} disabled{% endif %}>
                        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M3 2.5l10 5.5-10 5.5V2.5z"/></svg>
                        {% if syncRunning %}Syncing…{% else %}Import works{% endif %}
                    </button>
                </form>
                <span class="card-status{% if syncRunning %} running{% endif %}" id="sync-status">
                    {%- if syncRunning %}● Running{% else %}Idle{% endif -%}
                </span>
            </div>
        </div>

        <div class="stat-card">
            <div>
                <div class="value">{{ worksWithDetail|number_format(0, '.', ' ') }}</div>
                <div class="label">With details</div>
            </div>
            <div class="card-action">
                {% if worksWithoutDetail > 0 %}
                <form id="start-form" action="{{ path('app_imslp_fetch_start') }}" method="post">
                    <button type="submit" class="btn-card" id="start-btn"{% if running %} disabled{% endif %}>
                        <svg viewBox="0 0 16 16" fill="currentColor"><path d="M3 2.5l10 5.5-10 5.5V2.5z"/></svg>
                        {% if running %}Fetching…{% else %}Fetch details{% endif %}
                    </button>
                </form>
                <span class="card-status{% if running %} running{% endif %}" id="fetch-status">
                    {%- if running %}● Running{% else %}Idle{% endif -%}
                </span>
                {% else %}
                <span class="card-status" style="color:#6ec87a;">✓ Complete</span>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- Progress cards -->
    <div class="progress-grid">

        <!-- Works sync -->
        <div class="progress-card">
            <div class="progress-card-header">
                <h2>Works sync</h2>
                <span class="ps-badge {% if syncRunning %}running{% else %}idle{% endif %}">
                    {% if syncRunning %}● Running{% else %}Idle{% endif %}
                </span>
            </div>
            <div class="ps-stat">
                <span class="ps-number">{{ works|number_format }}</span>
                <span class="ps-sublabel">works in catalogue</span>
            </div>
            {% if syncRunning %}
            <p style="font-size:.78rem;color:#6a6058;text-align:center;">Fetching new works from IMSLP API…</p>
            {% else %}
            <p style="font-size:.78rem;color:#6a6058;text-align:center;">
                {% if works > 0 %}Ready — will resume from last offset{% else %}Not yet run{% endif %}
            </p>
            {% endif %}
            <details class="log-details" id="sync-log-details">
                <summary>Log</summary>
                <div class="log-box" id="sync-log-box">(loading…)</div>
            </details>
        </div>

        <!-- Detail fetch -->
        <div class="progress-card">
            <div class="progress-card-header">
                <h2>Detail fetch</h2>
                <span class="ps-badge {% if running %}running{% else %}idle{% endif %}">
                    {% if running %}● Running{% else %}Idle{% endif %}
                </span>
            </div>
            <div class="progress-label-row">
                <span>{{ worksWithDetail|number_format }} of {{ works|number_format }}</span>
                <span class="pct">{{ detailPercent }}%</span>
            </div>
            <div class="progress-bar-track">
                <div class="progress-bar-fill{% if running %} animated{% endif %}"
                     style="width: {{ detailPercent }}%"></div>
            </div>
            {% if worksWithoutDetail > 0 %}
                <p class="remaining">{{ worksWithoutDetail|number_format }} remaining</p>
            {% else %}
                <p class="remaining" style="color:#6ec87a;">✓ All works fetched</p>
            {% endif %}
            <details class="log-details" id="fetch-log-details">
                <summary>Log</summary>
                <div class="log-box" id="fetch-log-box">(loading…)</div>
            </details>
        </div>

    </div>

</div>

<script>
(function () {
    const fetchRunning = {{ running ? 'true' : 'false' }};
    const syncRunning  = {{ syncRunning ? 'true' : 'false' }};

    // Load log into box when the <details> is opened
    function setupLog(detailsId, boxId, url) {
        const details = document.getElementById(detailsId);
        const box     = document.getElementById(boxId);
        if (!details || !box) return;

        function load() {
            fetch(url)
                .then(r => r.ok ? r.text() : Promise.reject())
                .then(txt => { box.textContent = txt || '(no output yet)'; box.scrollTop = box.scrollHeight; })
                .catch(() => { box.textContent = '(log not available)'; });
        }

        details.addEventListener('toggle', function () {
            if (details.open) load();
        });

        // Keep refreshing while open if the job is running
        setInterval(function () {
            if (details.open) load();
        }, 5000);
    }

    setupLog('sync-log-details',  'sync-log-box',  '{{ path('app_imslp_sync_log') }}');
    setupLog('fetch-log-details', 'fetch-log-box', '{{ path('app_imslp_fetch_log') }}');

    // Wire action buttons
    function wireForm(formId, btnId, statusId, startLabel, runningLabel) {
        const form = document.getElementById(formId);
        if (!form) return;
        form.addEventListener('submit', function (e) {
            e.preventDefault();
            const btn    = document.getElementById(btnId);
            const status = document.getElementById(statusId);
            btn.disabled = true;
            btn.textContent = 'Starting…';
            fetch(form.action, { method: 'POST' })
                .then(r => r.json())
                .then(data => {
                    if (data.started) {
                        btn.textContent = runningLabel;
                        if (status) { status.textContent = '● Running'; status.className = 'card-status running'; }
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        btn.disabled = false;
                        btn.textContent = startLabel;
                        alert('Could not start: ' + (data.message || 'unknown error'));
                    }
                })
                .catch(() => location.reload());
        });
    }

    wireForm('start-form', 'start-btn', 'fetch-status', 'Fetch details', 'Fetching…');
    wireForm('sync-form',  'sync-btn',  'sync-status',  'Import works',  'Syncing…');

    // Auto-reload while any job is running
    if (fetchRunning || syncRunning) {
        setTimeout(() => location.reload(), 10000);
    }
})();
</script>
{% endblock %}
