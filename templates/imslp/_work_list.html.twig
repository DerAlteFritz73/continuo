{# Reusable work list + pagination partial.
   Variables: works, composerDates (map name→{born,died}), page, pages, urlParams (dict), showComposer (bool) #}
{% set showComposer = showComposer ?? false %}
{% set composerDates = composerDates ?? {} %}

<div class="work-list">
    {% for work in works %}
    {% set dates = composerDates[work.composer] ?? null %}
    <div class="work-item">
        <div>
            {# Line 1: composer #}
            <div class="work-composer">
                {% if showComposer %}
                <a class="clink"
                   href="{{ path('app_imslp', urlParams|merge({composer: work.composer, page: null})) }}">{{ work.composer }}</a>
                {% else %}
                <span>{{ work.composer }}</span>
                {% endif %}
                {% if dates %}
                <span class="composer-dates">({{ dates.born ?: '?' }}–{{ dates.died ?: '?' }})</span>
                {% endif %}
            </div>

            {# Line 2: title + year #}
            <div class="work-title">
                <a class="work-link" href="{{ path('app_imslp_work', {pageId: work.pageId}) }}">{{ work.title }}</a>
                {% if work.yearComposed %}<span class="work-year">{{ work.yearComposed }}</span>{% endif %}
            </div>

            {# Line 3: key, instrumentation, tags #}
            {% if work.workKey or work.instrumentation %}
            <div class="work-details">
                {% if work.workKey %}<span class="work-key">{{ work.workKey }}</span>{% endif %}
                {% if work.instrumentation %}<span class="work-instr-text">{{ work.instrumentation }}</span>{% endif %}
            </div>
            {% endif %}
        </div>
        {% if work.pieceStyle %}
        <div><span class="badge-style">{{ work.pieceStyle }}</span></div>
        {% endif %}
    </div>
    {% endfor %}
</div>

{% if pages > 1 %}
{% set w = 2 %}
<nav class="pagination" aria-label="Pages">
    {% if page > 1 %}
    <a href="{{ path('app_imslp', urlParams|merge({page: page - 1})) }}">&laquo;</a>
    {% endif %}

    {% set vp = [] %}
    {% for p in 1..pages %}
        {% if p == 1 or p == pages or (p >= page - w and p <= page + w) %}
            {% set vp = vp|merge([p]) %}
        {% endif %}
    {% endfor %}

    {% for p in vp %}
        {% if loop.index0 > 0 and p > vp[loop.index0 - 1] + 1 %}
            <span class="ellipsis">…</span>
        {% endif %}
        {% if p == page %}
            <span class="current">{{ p }}</span>
        {% else %}
            <a href="{{ path('app_imslp', urlParams|merge({page: p})) }}">{{ p }}</a>
        {% endif %}
    {% endfor %}

    {% if page < pages %}
    <a href="{{ path('app_imslp', urlParams|merge({page: page + 1})) }}">&raquo;</a>
    {% endif %}
</nav>
{% endif %}
