{% extends 'base.html.twig' %}

{% block title %}
    {%- if mode == 'composer' -%}{{ composer }} — IMSLP
    {%- elseif q -%}Search "{{ q }}" — IMSLP
    {%- else -%}IMSLP Browser{%- endif -%}
{% endblock %}

{% block head %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
    background: #1a1a1a;
    color: #e8e0d4;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    min-height: 100vh;
}
.wrapper {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
}

/* ── Header ── */
.site-header {
    text-align: center;
    margin-bottom: 2.5rem;
}
.site-header h1 {
    font-family: 'Playfair Display', serif;
    font-size: 2.4rem;
    color: #f0e6c8;
    letter-spacing: .03em;
}
.site-header .subtitle {
    font-size: .85rem;
    color: #8a8070;
    text-transform: uppercase;
    letter-spacing: .12em;
    margin-bottom: .5rem;
}
.back-link {
    display: inline-block;
    color: #c8a96e;
    text-decoration: none;
    font-size: .85rem;
    margin-bottom: 1.5rem;
}
.back-link:hover { text-decoration: underline; }

/* ── Search card ── */
.search-card {
    background: #252525;
    border: 1px solid #333;
    border-radius: 10px;
    padding: 1.5rem;
    margin-bottom: 2rem;
}
.search-row {
    display: flex;
    gap: .75rem;
    flex-wrap: wrap;
    align-items: flex-end;
}
.search-field {
    display: flex;
    flex-direction: column;
    gap: .35rem;
    flex: 1;
    min-width: 150px;
}
.search-field label {
    font-size: .75rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: #9a8a78;
}
.search-field input,
.search-field select {
    background: #1a1a1a;
    border: 1px solid #3a3a3a;
    border-radius: 6px;
    color: #e8e0d4;
    font-family: inherit;
    font-size: .9rem;
    padding: .55rem .8rem;
    outline: none;
    transition: border-color .2s;
}
.search-field input:focus,
.search-field select:focus { border-color: #c8a96e; }
.search-field input.ai-filled { border-color: #c8a96e88; background: #1e1a14; }
.search-field select option { background: #252525; }
.search-field.narrow { min-width: 90px; flex: 0 0 100px; }
.search-field.medium { min-width: 120px; flex: 0 1 160px; }
.btn-search {
    background: #c8a96e;
    color: #1a1a1a;
    border: none;
    border-radius: 6px;
    font-family: inherit;
    font-size: .9rem;
    font-weight: 600;
    padding: .55rem 1.4rem;
    cursor: pointer;
    white-space: nowrap;
    transition: background .2s;
    align-self: flex-end;
}
.btn-search:hover { background: #d9be88; }
.search-divider {
    border: none;
    border-top: 1px solid #2e2e2e;
    margin: 1rem 0 .75rem;
}

/* ── AI search section ── */
.ai-section {
    margin-bottom: 1rem;
}
.ai-row {
    display: flex;
    gap: .6rem;
    align-items: flex-end;
}
.ai-input {
    flex: 1;
    background: #1a1a1a;
    border: 1px solid #3a3a3a;
    border-radius: 6px;
    color: #e8e0d4;
    font-family: inherit;
    font-size: .9rem;
    padding: .55rem .8rem;
    outline: none;
    transition: border-color .2s;
}
.ai-input:focus { border-color: #c8a96e; }
.ai-input::placeholder { color: #5a524a; }
.btn-ai {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    background: #2a2520;
    border: 1px solid #c8a96e55;
    color: #c8a96e;
    border-radius: 6px;
    font-family: inherit;
    font-size: .85rem;
    font-weight: 600;
    padding: .55rem 1rem;
    cursor: pointer;
    white-space: nowrap;
    transition: background .2s, border-color .2s;
}
.btn-ai:hover { background: #342e26; border-color: #c8a96e; }
.btn-ai:disabled { opacity: .5; cursor: not-allowed; }
.ai-chips {
    display: flex;
    flex-wrap: wrap;
    gap: .35rem;
    margin-top: .55rem;
    min-height: 1.4rem;
}
.ai-chip {
    font-size: .72rem;
    background: #1e1a14;
    border: 1px solid #c8a96e44;
    color: #c8a96e;
    border-radius: 999px;
    padding: .15rem .6rem;
    font-family: 'Courier New', monospace;
}
.ai-chip.ai-chip-label {
    font-family: inherit;
    color: #8a8070;
    border-color: #3a3a3a;
    background: transparent;
}
.ai-error { font-size: .78rem; color: #c87a6e; margin-top: .4rem; }

.db-status {
    font-size: .8rem;
    color: #6a6058;
    margin-top: 1rem;
    text-align: right;
}
.db-status strong { color: #9a8a78; }

/* ── Composer cards ── */
.section-label {
    font-size: .75rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: #6a6058;
    margin-bottom: .75rem;
}
.section-label strong { color: #9a8a78; }
.composer-cards {
    display: flex;
    flex-wrap: wrap;
    gap: .6rem;
    margin-bottom: 2.5rem;
}
.composer-card {
    display: flex;
    flex-direction: column;
    background: #252525;
    border: 1px solid #3a3a3a;
    border-radius: 8px;
    padding: .75rem 1.1rem;
    text-decoration: none;
    color: inherit;
    transition: border-color .2s, background .2s;
    min-width: 180px;
    max-width: 280px;
}
.composer-card:hover {
    border-color: #c8a96e88;
    background: #2a2a2a;
}
.composer-card .cname {
    font-family: 'Playfair Display', serif;
    font-size: .95rem;
    color: #f0e6c8;
    line-height: 1.3;
}
.composer-card .ccount {
    font-size: .75rem;
    color: #8a8070;
    margin-top: .2rem;
}

/* ── Composer browse header ── */
.composer-browse-header {
    margin-bottom: 1.5rem;
}
.composer-browse-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.9rem;
    color: #f0e6c8;
    line-height: 1.2;
    margin-bottom: .25rem;
}
.composer-browse-header .work-count {
    font-size: .85rem;
    color: #8a8070;
}
.filter-bar {
    background: #252525;
    border: 1px solid #333;
    border-radius: 8px;
    padding: 1rem 1.2rem;
    margin-bottom: 1.5rem;
}

/* ── Section divider ── */
.section-divider {
    border: none;
    border-top: 1px solid #2a2a2a;
    margin: 2rem 0 1.5rem;
}

/* ── Results ── */
.results-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1rem;
    color: #8a8070;
    font-size: .85rem;
}
.results-header strong { color: #c8a96e; font-size: 1rem; }
.work-list { display: flex; flex-direction: column; gap: .5rem; }
.work-item {
    position: relative;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: .5rem 1rem;
    align-items: start;
    background: #252525;
    border: 1px solid #2e2e2e;
    border-radius: 8px;
    padding: .9rem 1.1rem;
    color: inherit;
    transition: border-color .2s, background .2s;
}
.work-item:hover { border-color: #c8a96e44; background: #2a2a2a; }
.work-link::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 8px;
}
.work-composer {
    font-size: .82rem;
    color: #9a8a78;
    margin-bottom: .18rem;
}
.work-composer .clink {
    position: relative;
    z-index: 1;
    color: #c8a96e;
    text-decoration: none;
}
.work-composer .clink:hover { text-decoration: underline; }
.composer-dates {
    font-size: .75rem;
    color: #6a6058;
    margin-left: .3rem;
}
.work-title {
    display: flex;
    align-items: baseline;
    gap: .5rem;
    flex-wrap: wrap;
}
.work-link {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    color: #f0e6c8;
    line-height: 1.3;
    text-decoration: none;
}
.work-title .catalog {
    position: relative;
    z-index: 1;
    font-family: 'Inter', sans-serif;
    font-size: .8rem;
    color: #6a6058;
    font-style: normal;
}
.work-year {
    font-size: .8rem;
    color: #8a8070;
    white-space: nowrap;
}
.work-details {
    font-size: .78rem;
    color: #6a6058;
    margin-top: .2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0 .6rem;
}
.work-key { color: #9a8a78; }
.work-instr-text { color: #8a8070; }
.work-tags-text { color: #5a5248; }
.badge-style {
    font-size: .7rem;
    background: #2e2e2e;
    border: 1px solid #3a3a3a;
    border-radius: 12px;
    padding: .15rem .55rem;
    color: #9a8a78;
    white-space: nowrap;
}

/* ── Pagination ── */
.pagination {
    display: flex;
    gap: .4rem;
    justify-content: center;
    margin-top: 2rem;
    flex-wrap: wrap;
}
.pagination a, .pagination span {
    display: inline-block;
    padding: .35rem .75rem;
    border-radius: 5px;
    font-size: .85rem;
    text-decoration: none;
    border: 1px solid #333;
    color: #c8a96e;
    background: #252525;
    transition: background .15s;
}
.pagination a:hover { background: #2e2e2e; }
.pagination span.current { background: #c8a96e22; border-color: #c8a96e; color: #f0e6c8; }
.pagination span.ellipsis { border: none; background: none; color: #6a6058; }

/* ── Empty state ── */
.empty-state { text-align: center; padding: 3rem 2rem; color: #6a6058; }
.empty-state .icon { font-size: 3rem; margin-bottom: 1rem; }
.empty-state h2 { font-family: 'Playfair Display', serif; color: #8a8070; margin-bottom: .5rem; }
.abbrev-table { margin: 1rem auto 0; border-collapse: collapse; font-size: .82rem; }
.abbrev-table td { padding: .25rem .7rem; text-align: left; }
.abbrev-table td:nth-child(odd) {
    font-family: 'Courier New', monospace;
    color: #c8a96e;
    text-align: right;
    padding-right: .4rem;
}
.abbrev-table td:nth-child(even) { color: #9a8a78; padding-right: 1.5rem; }
.abbrev-section {
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: #6a6058;
    padding: .6rem 0 .2rem;
    text-align: left;
}
.empty-state code {
    background: #252525;
    border: 1px solid #333;
    border-radius: 4px;
    padding: .1rem .4rem;
    font-size: .8rem;
    color: #c8a96e;
}

/* ── Responsive ── */
@media (max-width: 600px) {
    .search-row { flex-direction: column; }
    .site-header h1 { font-size: 1.8rem; }
    .composer-card { max-width: 100%; }
}
</style>
{% endblock %}

{% block body %}
<div class="wrapper">

    <a class="back-link" href="{{ path('app_home') }}">← Basso Continuo Realizer</a>

    <header class="site-header">
        <p class="subtitle">Petrucci Music Library</p>
        <h1>IMSLP Browser</h1>
    </header>

    {# ── Search form ── #}
    <div class="search-card">

        {# AI search #}
        <div class="ai-section">
            <div class="ai-row">
                <input type="text" id="ai-query" class="ai-input"
                       placeholder="Describe what you're looking for… e.g. Baroque trio sonatas for two violins and basso continuo">
                <button type="button" id="ai-btn" class="btn-ai">
                    <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor">
                        <path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm.75 10.5h-1.5v-5h1.5v5zm0-6.5h-1.5V3.5h1.5V5z"/>
                    </svg>
                    Ask AI
                </button>
            </div>
            <div class="ai-chips" id="ai-chips"></div>
        </div>

        <hr class="search-divider">

        <form method="get" action="{{ path('app_imslp') }}" id="search-form">
            {% if mode == 'composer' %}<input type="hidden" name="composer" value="{{ composer }}">{% endif %}
            {# Row 1: title/composer + instrumentation + style + search button #}
            <div class="search-row" style="margin-bottom:.6rem">
                <div class="search-field">
                    <label for="q">Composer / Title</label>
                    <input type="text" id="q" name="q"
                           value="{{ mode == 'composer' ? composer : q }}"
                           placeholder="e.g. Telemann, Sonata…" autofocus>
                </div>
                <div class="search-field">
                    <label for="instrumentation">Instrumentation</label>
                    <input type="text" id="f-instrumentation" name="instrumentation"
                           value="{{ filters.instrumentation }}" placeholder="e.g. fl vn viol bc">
                </div>
                <div class="search-field medium">
                    <label for="f-style">Period</label>
                    <select id="f-style" name="style">
                        <option value="">— any —</option>
                        {% set activeStyle = filters.style ?: composerStyle|default('') %}
                        {% for s in styles %}
                        <option value="{{ s }}" {% if s == activeStyle %}selected{% endif %}>{{ s }}</option>
                        {% endfor %}
                    </select>
                </div>
                <button type="submit" class="btn-search">Search</button>
            </div>
            {# Row 2: advanced filters #}
            <div class="search-row">
                <div class="search-field">
                    <label for="f-genre">Genre</label>
                    <input type="text" id="f-genre" name="genre"
                           value="{{ filters.genre }}" placeholder="sonatas, concertos…"
                           list="genre-list" autocomplete="off">
                    <datalist id="genre-list">
                        {% for g in genres %}<option value="{{ g }}">{% endfor %}
                    </datalist>
                </div>
                <div class="search-field medium">
                    <label for="f-key">Key</label>
                    <input type="text" id="f-key" name="key"
                           value="{{ filters.key }}" placeholder="D minor…">
                </div>
                <div class="search-field narrow">
                    <label for="f-year-from">Year from</label>
                    <input type="number" id="f-year-from" name="year_from"
                           value="{{ filters.yearFrom ?: '' }}" placeholder="1600" min="800" max="2100">
                </div>
                <div class="search-field narrow">
                    <label for="f-year-to">to</label>
                    <input type="number" id="f-year-to" name="year_to"
                           value="{{ filters.yearTo ?: '' }}" placeholder="1800" min="800" max="2100">
                </div>
            </div>
        </form>

        <div class="db-status" id="db-status">
            Loading… · <a href="{{ path('app_imslp_sync_status') }}" style="color:#c8a96e;text-decoration:none">Import status ↗</a>
        </div>
    </div>

    {# Clean filter params — null values are omitted from path() query strings #}
    {% set fp = {
        instrumentation: filters.instrumentation ?: null,
        style:           filters.style           ?: null,
        genre:           filters.genre           ?: null,
        key:             filters.key             ?: null,
        year_from:       filters.yearFrom        ?: null,
        year_to:         filters.yearTo          ?: null
    } %}

    {# ════════════════════════════════════════════════════════════════
       MODE: composer browse
    ════════════════════════════════════════════════════════════════ #}
    {% if mode == 'composer' %}

        {% if q %}
        <a class="back-link" href="{{ path('app_imslp', {q: q}) }}">← Back to results for "{{ q }}"</a>
        {% endif %}

        <div class="composer-browse-header">
            <h2>{{ composer }}</h2>
            <span class="work-count">
                {{ total|number_format }} work{{ total != 1 ? 's' : '' }}
                {% if not filters.isEmpty() %} matching filter{% endif %}
            </span>
        </div>

        {% if works is not empty %}
            {% include 'imslp/_work_list.html.twig' with {
                works: works, page: page, pages: pages, composerDates: composerDates,
                urlParams: {composer: composer, q: q ?: null}|merge(fp)
            } %}
        {% else %}
            <div class="empty-state">
                <div class="icon">♩</div>
                <h2>No works match this filter</h2>
                <p>Try removing the instrumentation or style filter.</p>
            </div>
        {% endif %}

    {# ════════════════════════════════════════════════════════════════
       MODE: text search — composer cards + title matches
    ════════════════════════════════════════════════════════════════ #}
    {% elseif mode == 'search' %}

        {# Composer cards #}
        {% if composerMatches is not empty %}
        <div>
            <p class="section-label">Composers <strong>({{ composerMatches|length }})</strong></p>
            <div class="composer-cards">
                {% for c in composerMatches %}
                <a class="composer-card"
                   href="{{ path('app_imslp', {composer: c.name, q: q ?: null}|merge(fp)) }}">
                    <span class="cname">{{ c.name }}</span>
                    <span class="ccount">{{ c.work_count|number_format }} works</span>
                </a>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        {# Title matches #}
        {% if total > 0 or composerMatches is empty %}
        <div>
            <p class="section-label">
                Works with <em>"{{ q }}"</em> in title
                {% if total > 0 %}<strong>({{ total|number_format }})</strong>{% endif %}
                {% if not filters.isEmpty() %} · filtered{% endif %}
            </p>

            {% if works is not empty %}
                {% include 'imslp/_work_list.html.twig' with {
                    works: works, page: page, pages: pages, composerDates: composerDates,
                    urlParams: {q: q ?: null}|merge(fp),
                    showComposer: true
                } %}
            {% else %}
                <p style="color:#6a6058;font-size:.9rem;padding:.5rem 0">No title matches found.</p>
            {% endif %}
        </div>
        {% endif %}

        {% if composerMatches is empty and works is empty %}
        <div class="empty-state">
            <div class="icon">♩</div>
            <h2>No results for "{{ q }}"</h2>
            <p>Try a different spelling or a broader search term.</p>
        </div>
        {% endif %}

    {# ════════════════════════════════════════════════════════════════
       MODE: instrumentation / style only
    ════════════════════════════════════════════════════════════════ #}
    {% elseif mode == 'filter' %}

        <div class="results-header">
            <div>
                {% if total > 0 %}
                    <strong>{{ total|number_format }}</strong> work{{ total != 1 ? 's' : '' }}
                    {% if pages > 1 %} — page {{ page }} / {{ pages }}{% endif %}
                {% else %}
                    No works found
                {% endif %}
            </div>
            <div><em style="font-size:.8rem">Instrumentation filter applies to detail-synced works only.</em></div>
        </div>

        {% if works is not empty %}
            {% include 'imslp/_work_list.html.twig' with {
                works: works, page: page, pages: pages, composerDates: composerDates,
                urlParams: fp,
                showComposer: true
            } %}
        {% else %}
            <div class="empty-state">
                <div class="icon">♩</div>
                <h2>No works found</h2>
                <p>Try different abbreviations. Instrumentation filter only applies to detail-synced works.</p>
            </div>
        {% endif %}

    {# ════════════════════════════════════════════════════════════════
       MODE: empty — show abbreviations table
    ════════════════════════════════════════════════════════════════ #}
    {% else %}
    <div class="empty-state">
        <div class="icon">𝄞</div>
        <h2>Search the IMSLP catalogue</h2>
        <p>Enter a composer name or work title above.<br>Use the instrumentation box with IMSLP abbreviations:</p>
        <table class="abbrev-table">
            <thead><tr><th colspan="6" class="abbrev-section">Instruments</th></tr></thead>
            <tbody>
                <tr><td>fl</td><td>flute</td>      <td>ob</td><td>oboe</td>             <td>cl</td><td>clarinet</td></tr>
                <tr><td>bn</td><td>bassoon</td>     <td>hn</td><td>horn</td>             <td>tr</td><td>trumpet</td></tr>
                <tr><td>vn</td><td>violin</td>      <td>va</td><td>viola</td>            <td>vc</td><td>cello</td></tr>
                <tr><td>viol</td><td>viola da gamba</td><td>db</td><td>double bass</td>  <td>str</td><td>strings</td></tr>
                <tr><td>hpd</td><td>harpsichord</td><td>org</td><td>organ</td>           <td>pf</td><td>piano</td></tr>
                <tr><td>lute</td><td>lute</td>      <td>bc</td><td>basso continuo</td>   <td></td><td></td></tr>
            </tbody>
            <thead><tr><th colspan="6" class="abbrev-section">Voices</th></tr></thead>
            <tbody>
                <tr><td>sop</td><td>soprano</td>    <td>mez</td><td>mezzo-soprano</td>   <td>alt</td><td>alto</td></tr>
                <tr><td>ten</td><td>tenor</td>       <td>bass</td><td>bass voice</td>    <td>v</td><td>voice (any)</td></tr>
                <tr><td>ch</td><td>choir</td>        <td>mch</td><td>male choir</td>     <td>vv</td><td>voices (e.g. 2vv)</td></tr>
            </tbody>
        </table>
        <p style="margin-top:.8rem;font-size:.8rem;">e.g. <code>fl vn viol bc</code> &nbsp;·&nbsp; <code>fl vn va bc</code> &nbsp;·&nbsp; <code>sop alt ten bass bc</code></p>
    </div>
    {% endif %}

</div>

<script>
fetch('{{ path('app_imslp_sync_status') }}?json')
    .then(r => r.json())
    .then(d => {
        document.getElementById('db-status').innerHTML =
            '<strong>' + d.works.toLocaleString() + '</strong> works · ' +
            '<strong>' + d.worksWithDetail.toLocaleString() + '</strong> with detail · ' +
            '<strong>' + d.composers.toLocaleString() + '</strong> composers' +
            ' · <a href="{{ path('app_imslp_sync_status') }}" style="color:#c8a96e;text-decoration:none" onmouseover="this.style.textDecoration=\'underline\'" onmouseout="this.style.textDecoration=\'none\'">Import status ↗</a>';
    })
    .catch(() => { document.getElementById('db-status').textContent = ''; });

// ── Strip empty params from search form before submit ──
document.getElementById('search-form').addEventListener('submit', function () {
    this.querySelectorAll('input, select').forEach(el => {
        if (el.value === '' || el.value === null) el.disabled = true;
    });
});

// ── AI search ──
(function () {
    const btn    = document.getElementById('ai-btn');
    const input  = document.getElementById('ai-query');
    const chips  = document.getElementById('ai-chips');
    const form   = document.getElementById('search-form');

    const FIELD_LABELS = {
        instrumentation: 'Instrumentation',
        style:           'Period',
        genre:           'Genre',
        key:             'Key',
        year_from:       'From',
        year_to:         'To',
        composer:        'Composer',
        title:           'Title',
    };

    function setChips(filters) {
        chips.innerHTML = '';
        let any = false;
        for (const [k, v] of Object.entries(filters)) {
            if (!v || k === 'error') continue;
            any = true;
            const label = document.createElement('span');
            label.className = 'ai-chip ai-chip-label';
            label.textContent = FIELD_LABELS[k] || k;
            const val = document.createElement('span');
            val.className = 'ai-chip';
            val.textContent = v;
            chips.appendChild(label);
            chips.appendChild(val);
        }
        return any;
    }

    function fillForm(filters) {
        const map = {
            instrumentation: 'f-instrumentation',
            style:           'f-style',
            genre:           'f-genre',
            key:             'f-key',
            year_from:       'f-year-from',
            year_to:         'f-year-to',
        };
        for (const [key, elId] of Object.entries(map)) {
            if (filters[key]) {
                const el = document.getElementById(elId);
                if (el) {
                    el.value = filters[key];
                    el.classList.add('ai-filled');
                }
            }
        }
        // composer / title go into the q field
        if (filters.composer && !filters.title) {
            const q = document.getElementById('q');
            if (q) { q.value = filters.composer; q.classList.add('ai-filled'); }
        } else if (filters.title) {
            const q = document.getElementById('q');
            if (q) { q.value = filters.title; q.classList.add('ai-filled'); }
        }
    }

    btn.addEventListener('click', async () => {
        const query = input.value.trim();
        if (!query) return;

        btn.disabled = true;
        btn.textContent = 'Thinking…';
        chips.innerHTML = '';

        try {
            const resp = await fetch('{{ path('app_imslp_ai_search') }}', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({query}),
            });
            const data = await resp.json();

            if (data.error) {
                const err = document.createElement('div');
                err.className = 'ai-error';
                err.textContent = data.error;
                chips.appendChild(err);
            } else {
                const any = setChips(data);
                if (any) fillForm(data);
                else {
                    const err = document.createElement('div');
                    err.className = 'ai-error';
                    err.textContent = 'No filters could be extracted. Try rephrasing.';
                    chips.appendChild(err);
                }
            }
        } catch (e) {
            const err = document.createElement('div');
            err.className = 'ai-error';
            err.textContent = 'Request failed. Check your connection.';
            chips.appendChild(err);
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm.75 10.5h-1.5v-5h1.5v5zm0-6.5h-1.5V3.5h1.5V5z"/></svg> Ask AI';
        }
    });

    input.addEventListener('keydown', e => { if (e.key === 'Enter') btn.click(); });
})();
</script>
{% endblock %}
