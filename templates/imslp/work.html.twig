{% extends 'base.html.twig' %}

{% block title %}{{ work.title }} — IMSLP{% endblock %}

{% block head %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
    background: #1a1a1a;
    color: #e8e0d4;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    min-height: 100vh;
}
.wrapper {
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
}
.back-link {
    display: inline-block;
    color: #c8a96e;
    text-decoration: none;
    font-size: .85rem;
    margin-bottom: 1.5rem;
}
.back-link:hover { text-decoration: underline; }

/* ── Work header ── */
.work-header {
    margin-bottom: 2rem;
}
.work-header h1 {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    color: #f0e6c8;
    line-height: 1.25;
    margin-bottom: .4rem;
}
.work-header .composer-line {
    font-size: 1.1rem;
    color: #c8a96e;
    margin-bottom: .8rem;
}
.work-header .catalog-no {
    font-size: .85rem;
    color: #8a8070;
}

/* ── Metadata grid ── */
.meta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .6rem 2rem;
    background: #252525;
    border: 1px solid #333;
    border-radius: 10px;
    padding: 1.4rem 1.6rem;
    margin-bottom: 2rem;
}
@media (max-width: 600px) { .meta-grid { grid-template-columns: 1fr; } }
.meta-item {}
.meta-item dt {
    font-size: .72rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: #6a6058;
    margin-bottom: .15rem;
}
.meta-item dd {
    font-size: .9rem;
    color: #d8d0c4;
}

/* ── Files / Editions section ── */
.section-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    color: #f0e6c8;
    margin-bottom: 1rem;
    padding-bottom: .5rem;
    border-bottom: 1px solid #2e2e2e;
}

/* Edition card (one per #fte:imslpfile block) */
.edition-card {
    background: #222;
    border: 1px solid #333;
    border-radius: 10px;
    margin-bottom: .9rem;
    overflow: hidden;
}
.edition-header {
    padding: .75rem 1.1rem;
    background: #252525;
    border-bottom: 1px solid #2e2e2e;
    cursor: pointer;
    user-select: none;
    display: flex;
    align-items: flex-start;
    gap: .7rem;
}
.edition-header:hover { background: #2c2c2c; }
.edition-header-content { flex: 1 1 auto; min-width: 0; }
.edition-chevron {
    flex: 0 0 auto;
    color: #6a6058;
    font-size: .85rem;
    margin-top: .15rem;
    transition: transform .2s;
}
.edition-card.open .edition-chevron { transform: rotate(90deg); }
.edition-title {
    font-size: .92rem;
    color: #d8d0c4;
    font-weight: 500;
    margin-bottom: .25rem;
}
.edition-title em { color: #c8a96e; font-style: normal; }
.edition-meta {
    font-size: .75rem;
    color: #6a6058;
    display: flex;
    flex-wrap: wrap;
    gap: .3rem .9rem;
}
.edition-meta .copyright { color: #8a8070; }

/* Collapsible body — smooth grid expand */
.edition-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows .28s ease;
}
.edition-card.open .edition-body { grid-template-rows: 1fr; }
.edition-body-inner { overflow: hidden; }

/* ── Page-load fade-in ── */
@keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
}
.anim-fade-up {
    opacity: 0;
    animation: fadeUp .32s ease both;
}

/* Multi-file open panel */
.files-open-panel {
    padding: .45rem 1.1rem .55rem;
    background: #1e1e1e;
    border-bottom: 1px solid #2a2a2a;
}
.files-open-panel-title {
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: #6a6058;
    margin-bottom: .35rem;
}
.files-open-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: .2rem;
}
.files-open-link {
    color: #c8a96e;
    text-decoration: none;
    font-size: .8rem;
    font-family: monospace;
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
.files-open-link:hover { text-decoration: underline; }
.files-open-link:visited { color: #9a7a4e; }

/* RISM incipit panel */
.rism-panel {
    padding: .5rem 1.1rem .7rem;
    background: #1e1e1e;
    border-bottom: 1px solid #2a2a2a;
}
.rism-btn {
    background: none;
    border: 1px solid #3a3028;
    border-radius: 4px;
    color: #8a8070;
    font-size: .72rem;
    padding: .25rem .65rem;
    cursor: pointer;
    transition: border-color .15s, color .15s;
}
.rism-btn:hover { border-color: #c8a96e; color: #c8a96e; }
.rism-incipits { display: none; margin-top: .6rem; }
.rism-incipit-item { margin-bottom: .5rem; }
.rism-incipit-label {
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: .07em;
    color: #6a6058;
    margin-bottom: .25rem;
}
.rism-incipit-item { background: #f0ece2; border-radius: 4px; padding: .4rem .6rem; display: inline-block; }
.rism-incipit-item svg { max-width: 100%; height: auto; display: block; }
.rism-source-block { margin-bottom: 1.2rem; }
.rism-source-label {
    font-size: .75rem;
    color: #8a8070;
    margin-bottom: .4rem;
    padding-bottom: .25rem;
    border-bottom: 1px solid #2e2e2e;
}

/* Download progress bar */
.dl-progress {
    padding: .45rem 1.1rem .5rem;
    background: #1e1e1e;
    border-bottom: 1px solid #2a2a2a;
}
.dl-progress-track {
    height: 4px;
    background: #2e2e2e;
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: .35rem;
}
.dl-progress-fill {
    height: 100%;
    background: #c8a96e;
    border-radius: 2px;
    width: 0;
    transition: width .35s ease;
}
.dl-progress-label {
    font-size: .72rem;
    color: #6a6058;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

/* Actions bar */
.edition-actions {
    display: flex;
    align-items: center;
    gap: .8rem;
    padding: .55rem 1.1rem;
    background: #1e1e1e;
    border-bottom: 1px solid #2a2a2a;
    flex-wrap: wrap;
}
.select-all-label {
    display: flex;
    align-items: center;
    gap: .4rem;
    font-size: .8rem;
    color: #8a8070;
    cursor: pointer;
}
.select-all-label input { cursor: pointer; accent-color: #c8a96e; }
.select-all-label:hover { color: #c8a96e; }
.download-btn {
    margin-left: auto;
    background: #c8a96e;
    color: #1a1a1a;
    border: none;
    border-radius: 5px;
    padding: .35rem .85rem;
    font-size: .8rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity .2s;
}
.download-btn:hover { opacity: .85; }
.download-btn:disabled { opacity: .4; cursor: default; }

/* File rows inside an edition */
.edition-files {
    display: flex;
    flex-direction: column;
}
.file-row {
    display: flex;
    align-items: center;
    gap: .7rem;
    padding: .45rem 1.1rem;
    border-bottom: 1px solid #1e1e1e;
}
.file-row:last-child { border-bottom: none; }
.file-row:hover { background: #252525; }
.file-row input[type="checkbox"] {
    flex: 0 0 auto;
    cursor: pointer;
    accent-color: #c8a96e;
    width: 15px;
    height: 15px;
}
.file-row label {
    display: flex;
    align-items: baseline;
    gap: .6rem;
    flex: 1 1 auto;
    cursor: pointer;
    min-width: 0;
    flex-wrap: wrap;
}
.file-desc {
    font-size: .88rem;
    color: #d8d0c4;
    flex: 1 1 auto;
}
.file-name {
    font-family: monospace;
    font-size: .75rem;
    color: #6a6058;
    flex: 0 1 auto;
    word-break: break-all;
    text-align: right;
}

/* ── External links ── */
.ext-links {
    display: flex;
    flex-wrap: wrap;
    gap: .6rem;
    margin-bottom: 2rem;
}
.imslp-link, .yt-link, .sp-link {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    text-decoration: none;
    padding: .6rem 1.2rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: .9rem;
    transition: opacity .2s;
}
.imslp-link { background: #c8a96e; color: #1a1a1a; }
.imslp-link:hover { opacity: .85; }
.yt-link { background: #c4302b; color: #fff; }
.yt-link:hover { opacity: .85; }
.sp-link { background: #1db954; color: #fff; }
.sp-link:hover { opacity: .85; }

/* ── Movements list ── */
.movements-list {
    margin: .4rem 0 0 0;
    padding: 0;
    list-style: none;
    font-size: .88rem;
    color: #d8d0c4;
    line-height: 1.7;
    counter-reset: mvt;
}
.movements-header {
    font-size: .78rem;
    text-transform: uppercase;
    letter-spacing: .07em;
    color: #6a6058;
    margin-top: .6rem;
    margin-bottom: .1rem;
    padding-left: 0;
}
.movements-header:first-child { margin-top: 0; }
.movements-subheader {
    font-size: .85rem;
    color: #c8a96e;
    margin-top: .7rem;
    margin-bottom: .1rem;
    padding-left: .8rem;
    counter-reset: mvt;
    font-style: italic;
}
.movements-subheader:first-child { margin-top: 0; }
.movements-item {
    counter-increment: mvt;
    padding-left: 2.4rem;
    position: relative;
}
.movements-item::before {
    content: counter(mvt) ".";
    position: absolute;
    left: 0;
    color: #6a6058;
    font-size: .8rem;
    min-width: 2rem;
    text-align: right;
}

/* ── No detail notice ── */
.notice {
    background: #2a2520;
    border: 1px solid #3a3020;
    border-radius: 8px;
    padding: 1rem 1.2rem;
    font-size: .85rem;
    color: #9a8878;
    margin-bottom: 1.5rem;
}

/* ── Responsive ── */
@media (max-width: 600px) {
    .wrapper { padding: 1.5rem 1rem 2rem; }
    .work-header h1 { font-size: 1.5rem; }
    .work-header .composer-line { font-size: 1rem; }
    .meta-grid { padding: 1rem; }
    .file-name { text-align: left; }
    .edition-header { padding: .65rem .9rem; }
    .file-row { padding: .4rem .9rem; }
}

@media (max-width: 420px) {
    .wrapper { padding: 1rem 0.75rem 2rem; }
    .work-header h1 { font-size: 1.25rem; }
    .back-link { font-size: .8rem; }
    .imslp-link, .yt-link, .sp-link {
        flex: 1 1 100%;
        justify-content: center;
    }
    .meta-grid { padding: .85rem; border-radius: 8px; }
}
</style>
{% endblock %}

{% block body %}
<div class="wrapper">

    <a class="back-link" href="javascript:history.back()">{{ 'imslp.work_back_to_search'|trans }}</a>

    <div class="work-header">
        <h1>{{ work.title }}</h1>
        <div class="composer-line">{{ work.composer }}</div>
    </div>

    {% set searchQ = (work.composer ~ ' ' ~ work.title)|url_encode %}
    <div class="ext-links">
        <a class="imslp-link" href="{{ work.permlink }}" target="_blank" rel="noopener">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 1a7 7 0 1 0 0 14A7 7 0 0 0 8 1zm0 1.5a5.5 5.5 0 1 1 0 11 5.5 5.5 0 0 1 0-11zM7 5v5h2V5H7zm0 6v1.5h2V11H7z"/></svg>
            {{ 'imslp.work_imslp_link'|trans }}
        </a>
        <a class="yt-link" href="https://www.youtube.com/results?search_query={{ searchQ }}" target="_blank" rel="noopener">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8.051 1.999h.089c.822.003 4.987.033 6.11.335a2.01 2.01 0 0 1 1.415 1.42c.101.38.172.883.22 1.402l.01.104.022.26.008.104c.065.914.073 1.77.074 1.957v.075c-.001.194-.01 1.108-.082 2.06l-.008.105-.009.104c-.05.572-.124 1.14-.235 1.558a2.01 2.01 0 0 1-1.415 1.42c-1.16.312-5.569.334-6.18.335h-.142c-.309 0-1.587-.006-2.927-.052l-.17-.006-.087-.004-.171-.007-.171-.007c-1.11-.049-2.167-.128-2.654-.26a2.01 2.01 0 0 1-1.415-1.419c-.111-.417-.185-.986-.235-1.558L.09 9.82l-.008-.104A31 31 0 0 1 0 7.68v-.122C.002 7.343.01 6.6.064 5.78l.007-.103.003-.052.008-.104.022-.26.01-.104c.048-.519.119-1.023.22-1.402a2.01 2.01 0 0 1 1.415-1.42c.487-.13 1.544-.21 2.654-.26l.17-.007.172-.006.086-.003.171-.007A100 100 0 0 1 7.858 2zM6.4 5.209v4.818l4.157-2.408z"/></svg>
            {{ 'imslp.work_youtube_link'|trans }}
        </a>
        <a class="sp-link" href="https://open.spotify.com/search/{{ searchQ }}" target="_blank" rel="noopener">
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0a8 8 0 1 0 0 16A8 8 0 0 0 8 0m3.669 11.538a.5.5 0 0 1-.686.165c-1.879-1.147-4.243-1.407-7.028-.77a.499.499 0 0 1-.222-.973c3.048-.696 5.662-.397 7.77.892a.5.5 0 0 1 .166.686m.979-2.178a.624.624 0 0 1-.858.205c-2.15-1.321-5.428-1.704-7.972-.932a.625.625 0 0 1-.362-1.194c2.905-.881 6.517-.454 8.986 1.063a.624.624 0 0 1 .206.858m.084-2.268C10.154 5.56 5.9 5.419 3.438 6.166a.748.748 0 1 1-.434-1.432c2.825-.857 7.523-.692 10.492 1.07a.747.747 0 1 1-.764 1.288z"/></svg>
            {{ 'imslp.work_spotify_link'|trans }}
        </a>
    </div>

    {% if not work.hasDetail() %}
    <div class="notice">
        {{ 'imslp.work_no_detail_notice'|trans }}
    </div>
    {% endif %}

    <!-- Metadata -->
    {% if work.hasDetail() %}
    <dl class="meta-grid">
        {% if work.workKey %}
        <div class="meta-item"><dt>{{ 'imslp.work_meta_key'|trans }}</dt><dd>{{ work.workKey }}</dd></div>
        {% endif %}
        {% if work.instrumentation %}
        <div class="meta-item"><dt>{{ 'imslp.work_meta_instrumentation'|trans }}</dt><dd>{{ work.instrumentation }}</dd></div>
        {% endif %}
        {% if work.pieceStyle %}
        <div class="meta-item"><dt>{{ 'imslp.work_meta_style'|trans }}</dt><dd>{{ work.pieceStyle }}</dd></div>
        {% endif %}
        {% if work.yearComposed %}
        <div class="meta-item"><dt>{{ 'imslp.work_meta_year_composed'|trans }}</dt><dd>{{ work.yearComposed }}</dd></div>
        {% endif %}
        {% if work.pageType %}
        <div class="meta-item"><dt>{{ 'imslp.work_meta_type'|trans }}</dt><dd>{{ work.pageType }}</dd></div>
        {% endif %}
        {% if work.movements %}
        <div class="meta-item" style="grid-column:1/-1">
            <dt>{{ 'imslp.work_meta_movements'|trans }}</dt>
            <dd>
                <ul class="movements-list">
                {% for line in work.movements|split('\n') %}
                    {% set line = line|trim %}
                    {% if line %}
                        {% if line ends with ':' %}
                            <li class="movements-header">{{ line|trim(':') }}</li>
                        {% elseif
                            ', TWV' in line or ', BWV' in line or ', HWV' in line or
                            ', RV'  in line or ', Op.' in line or ', op.' in line or
                            ', KV'  in line or ', K.'  in line or ', Wq'  in line or
                            ', WoO' in line or ', D.'  in line or ', L.'  in line or
                            ', Z.'  in line or ', H.'  in line or ', TH'  in line or
                            ', CT'  in line or ', T.'  in line or ', P.'  in line or
                            'No. '  in line or 'Nr. '  in line
                        %}
                            <li class="movements-subheader">{{ line }}</li>
                        {% else %}
                            <li class="movements-item">{{ line }}</li>
                        {% endif %}
                    {% endif %}
                {% endfor %}
                </ul>
            </dd>
        </div>
        {% endif %}
        {% if work.tags %}
        <div class="meta-item" style="grid-column:1/-1"><dt>{{ 'imslp.work_meta_tags'|trans }}</dt><dd>{{ work.tags }}</dd></div>
        {% endif %}
    </dl>
    {% endif %}

    {# Collect unique RISM source IDs from editions for work-level display #}
    {% set editionRismSources = [] %}
    {% set seenRismIds = [] %}
    {% for ed in work.filesJson ?? [] %}
        {% if ed.rismSourceId is defined and ed.rismSourceId and ed.rismSourceId not in seenRismIds %}
            {% set seenRismIds = seenRismIds|merge([ed.rismSourceId]) %}
            {% set edLabel = ed.publisher is defined and ed.publisher ? ed.publisher
                : (ed.editor is defined and ed.editor ? ed.editor
                : (ed.arranger is defined and ed.arranger ? ed.arranger
                : 'imslp.work_edition_anonymous'|trans)) %}
            {% set editionRismSources = editionRismSources|merge([{'id': ed.rismSourceId, 'label': edLabel}]) %}
        {% endif %}
    {% endfor %}

    {# Work-level RISM incipits — auto-loaded; hidden until results arrive #}
    {% if work.hasDetail() %}
    <div id="rism-work-section" style="display:none;margin-bottom:1.5rem">
        <button class="rism-btn" id="rism-work-btn" onclick="toggleRismPanel()">
            {{ 'imslp.work_rism_incipits'|trans }}
            <span id="rism-chevron" style="display:inline-block;transition:transform .2s;margin-left:.3rem">▾</span>
        </button>
        <div id="rism-work-panel" style="margin-top:.8rem"></div>
    </div>
    {% endif %}

    <!-- Files / Editions -->
    {% if work.filesJson is not empty %}
    {# Detect format: new = array of editions (each has a 'files' key);
       old = flat array of file objects (each has a 'filename' key directly) #}
    {% set isEditionFormat = work.filesJson[0] is defined and work.filesJson[0].files is defined %}

    {% if isEditionFormat %}
        {% set edCount = work.filesJson|length %}
        <h2 class="section-title">{{ 'imslp.work_files_title'|trans }} — {{ edCount != 1 ? 'imslp.work_files_editions_plural'|trans({'%editions%': edCount}) : 'imslp.work_files_editions'|trans({'%editions%': edCount}) }}</h2>

        {% for ed in work.filesJson %}
        {% set edIdx = loop.index %}
        {% set edLabel = ed.publisher is defined and ed.publisher ? ed.publisher : (ed.editor is defined and ed.editor ? ed.editor : (ed.arranger is defined and ed.arranger ? ed.arranger : 'Anonymous')) %}
        <div class="edition-card" id="edition-{{ edIdx }}"
             data-zipname="{{ (work.composer ~ ' - ' ~ work.title ~ ' - ' ~ edLabel)|e('html_attr') }}">
            <div class="edition-header" onclick="toggleEdition({{ edIdx }})">
                <div class="edition-header-content">
                    <div class="edition-title">
                        {% if ed.publisher is defined and ed.publisher %}
                            {{ ed.publisher }}
                        {% else %}
                            <span style="color:#6a6058;font-style:italic">{{ 'imslp.work_edition_anonymous'|trans }}</span>
                        {% endif %}
                        <span style="color:#6a6058;font-weight:400;font-size:.82rem;margin-left:.5rem">({{ ed.files|length }} {{ ed.files|length != 1 ? 'imslp.work_files_count_plural'|trans({'%count%': ''}) : 'imslp.work_files_count'|trans({'%count%': ''}) |trim }})</span>
                        {% set isManuscript = ed.imageType is defined and 'manuscript' in ed.imageType|lower %}
                        {% if not isManuscript %}
                            {% if ed.arranger is defined and ed.arranger %}
                                {# For arrangements: show what the piece is arranged for, then the arranger #}
                                {% set forText = ed.arrangementFor is defined and ed.arrangementFor ? ed.arrangementFor : '' %}
                                {% if forText %}
                                <div style="font-size:.85rem;color:#c8a96e;font-weight:500;margin-top:.2rem">{{ 'imslp.work_edition_for'|trans }} <em style="font-style:normal">{{ forText }}</em></div>
                                {% endif %}
                                <div style="font-size:.8rem;color:#8a8070;font-weight:400;margin-top:.1rem">{{ 'imslp.work_edition_arr'|trans }} <em style="color:#a89880">{{ ed.arranger }}</em>
                                    {# Fall back to miscNotes as instrumentation hint when arrangementFor is absent #}
                                    {% if not forText and ed.miscNotes is defined and ed.miscNotes and 'arrang' in ed.miscNotes|lower %}
                                        — <span style="color:#6a6058">{{ ed.miscNotes|split('\n')|first|trim }}</span>
                                    {% endif %}
                                </div>
                            {% elseif ed.editor is defined and ed.editor %}
                                <div style="font-size:.8rem;color:#8a8070;font-weight:400;margin-top:.15rem">{{ 'imslp.work_edition_ed'|trans }} <em style="color:#a89880">{{ ed.editor }}</em></div>
                            {% endif %}
                        {% endif %}
                    </div>
                    <div class="edition-meta">
                        {% if ed.dateSubmitted is defined and ed.dateSubmitted %}
                        <span>{{ 'imslp.work_edition_submitted'|trans({'%date%': ed.dateSubmitted}) }}</span>
                        {% endif %}
                        {% if ed.copyright is defined and ed.copyright %}
                        <span class="copyright">{{ ed.copyright }}</span>
                        {% endif %}
                    </div>
                </div>
                <span class="edition-chevron">▶</span>
            </div>
            <div class="edition-body"><div class="edition-body-inner">
                <div class="edition-actions">
                    <label class="select-all-label">
                        <input type="checkbox" class="select-all-cb" id="selAll-{{ edIdx }}" onchange="toggleSelectAll({{ edIdx }}, this.checked)">
                        <span id="selAllLabel-{{ edIdx }}">{{ 'imslp.work_edition_select_all'|trans }}</span>
                    </label>
                    <button class="download-btn" id="dlBtn-{{ edIdx }}" onclick="downloadZip({{ edIdx }})"
                            data-label-none="{{ 'imslp.work_edition_download_none'|trans }}"
                            data-label-selected="{{ 'imslp.work_edition_download_selected'|trans({'%count%': '__N__'}) }}"
                            disabled>
                        {{ 'imslp.work_edition_download_none'|trans }}
                    </button>
                </div>
                {% if ed.rismSourceId is defined and ed.rismSourceId %}
                <div class="rism-panel">
                    <button class="rism-btn" onclick="toggleIncipits({{ edIdx }}, '{{ ed.rismSourceId }}')">RISM incipits</button>
                    <div class="rism-incipits" id="rism-incipits-{{ edIdx }}"></div>
                </div>
                {% endif %}
                <div class="dl-progress" id="dl-progress-{{ edIdx }}" style="display:none">
                    <div class="dl-progress-track"><div class="dl-progress-fill" id="dl-fill-{{ edIdx }}"></div></div>
                    <div class="dl-progress-label" id="dl-label-{{ edIdx }}"></div>
                </div>
                <div class="files-open-panel" id="open-panel-{{ edIdx }}" style="display:none">
                    <div class="files-open-panel-title">{{ 'imslp.work_edition_open_panel_title'|trans }}</div>
                    <ul class="files-open-list" id="open-panel-list-{{ edIdx }}"></ul>
                </div>
                <div class="edition-files" id="files-{{ edIdx }}">
                    {% for file in ed.files %}
                    {% set fileIdx = loop.index %}
                    <div class="file-row">
                        <input type="checkbox" id="f-{{ edIdx }}-{{ fileIdx }}"
                               class="file-cb"
                               data-edition="{{ edIdx }}"
                               data-filename="{{ file.filename }}"
                               onchange="onFileCheck({{ edIdx }})">
                        <label for="f-{{ edIdx }}-{{ fileIdx }}">
                            <span class="file-desc">{{ file.description is defined and file.description ? file.description : file.filename }}</span>
                            {% if file.description is defined and file.description %}
                            <span class="file-name">{{ file.filename }}</span>
                            {% endif %}
                        </label>
                    </div>
                    {% endfor %}
                </div>
            </div></div>{# /edition-body-inner /edition-body #}
        </div>
        {% endfor %}

    {% else %}
        {# Legacy flat format #}
        <h2 class="section-title">{{ 'imslp.work_files_title'|trans }} ({{ work.filesJson|length }})</h2>
        {% for file in work.filesJson %}
        <div class="edition-card">
            <div class="edition-header" style="cursor:default">
                <div class="edition-header-content">
                    <div class="edition-meta">
                        {% if file.editor is defined and file.editor %}<span>Ed. {{ file.editor }}</span>{% endif %}
                        {% if file.publisher is defined and file.publisher %}<span>{{ file.publisher }}</span>{% endif %}
                        {% if file.copyright is defined and file.copyright %}<span class="copyright">{{ file.copyright }}</span>{% endif %}
                    </div>
                </div>
            </div>
            <div class="edition-files">
                <div class="file-row">
                    <label style="flex:1;cursor:default">
                        <span class="file-desc">{{ file.description is defined and file.description ? file.description : file.filename }}</span>
                        <span class="file-name">{{ file.filename }}</span>
                    </label>
                </div>
            </div>
        </div>
        {% endfor %}
    {% endif %}

    {% endif %}

<script>
const IMSLP_CREDENTIALS = {{ imslpCredentials ? 'true' : 'false' }};
const IMSLP_BASE = 'https://imslp.org/wiki/Special:IMSLPDisclaimerAccept/';
// RISM source IDs extracted from edition links in this work's filesJson
const EDITION_RISM_SOURCES = {{ editionRismSources|json_encode|raw }};

function toggleEdition(idx) {
    document.getElementById('edition-' + idx).classList.toggle('open');
}

function toggleRismPanel() {
    const panel   = document.getElementById('rism-work-panel');
    const chevron = document.getElementById('rism-chevron');
    const open    = panel.style.display !== 'none';
    panel.style.display   = open ? 'none' : 'block';
    if (chevron) chevron.style.transform = open ? 'rotate(-90deg)' : '';
}

// Auto-load RISM incipits on page load; reveal section only if data arrives.
(async function () {
    const section = document.getElementById('rism-work-section');
    if (!section) return;

    const collected = [];

    // 1. Edition-linked sources — parallel fetches (most reliable)
    if (EDITION_RISM_SOURCES.length) {
        await Promise.allSettled(
            EDITION_RISM_SOURCES.slice(0, 5).map(({ id, label }) =>
                fetch('/imslp/rism-incipits/' + id)
                    .then(r => r.json())
                    .then(items => {
                        const incipits = items.filter(i => i.svg).slice(0, 4)
                            .map(i => ({ svg: i.svg, label: i.label || null }));
                        if (incipits.length) collected.push({ source: label, incipits });
                    })
                    .catch(() => {})
            )
        );
    }

    // 2. Catalogue-number search — supplements with additional manuscript sources
    try {
        const resp = await fetch('/imslp/rism-work-incipits/{{ work.pageId }}');
        const data = await resp.json();
        for (const src of data.sources ?? []) collected.push({ source: src.source, incipits: src.incipits });
    } catch (_) {}

    if (!collected.length) return; // leave section hidden

    document.getElementById('rism-work-panel').innerHTML = collected.map(src => `
        <div class="rism-source-block">
            <div class="rism-source-label">${src.source}</div>
            ${(src.incipits || []).map(inc => `
                <div style="margin-bottom:.6rem">
                    ${inc.label ? `<div class="rism-incipit-label">${inc.label}</div>` : ''}
                    <div class="rism-incipit-item">${inc.svg}</div>
                </div>`).join('')}
        </div>`).join('');
    section.style.display = 'block';
})();

async function toggleIncipits(idx, rismId) {
    const panel = document.getElementById('rism-incipits-' + idx);
    if (panel.style.display === 'block') { panel.style.display = 'none'; return; }
    if (panel.dataset.loaded) { panel.style.display = 'block'; return; }

    panel.style.display = 'block';
    panel.innerHTML = '<span style="color:#6a6058;font-size:.8rem">Loading…</span>';

    try {
        const resp = await fetch('/imslp/rism-incipits/' + rismId);
        const items = await resp.json();
        if (!items.length) { panel.innerHTML = '<span style="color:#6a6058;font-size:.8rem">No incipits found.</span>'; return; }
        panel.innerHTML = items.filter(i => i.svg).map(inc => `
            <div style="margin-bottom:.6rem">
                ${inc.label ? `<div class="rism-incipit-label">${inc.label}</div>` : ''}
                <div class="rism-incipit-item">${inc.svg}</div>
            </div>`).join('');
        panel.dataset.loaded = '1';
    } catch (e) {
        panel.innerHTML = '<span style="color:#8a3020;font-size:.8rem">Failed to load.</span>';
    }
}

function getChecked(idx) {
    return Array.from(document.querySelectorAll('.file-cb[data-edition="' + idx + '"]:checked'));
}

function onFileCheck(idx) {
    const all     = document.querySelectorAll('.file-cb[data-edition="' + idx + '"]');
    const checked = getChecked(idx);
    const n       = checked.length;

    const selAllCb = document.getElementById('selAll-' + idx);
    selAllCb.indeterminate = n > 0 && n < all.length;
    selAllCb.checked = n === all.length && all.length > 0;

    const btn = document.getElementById('dlBtn-' + idx);
    btn.disabled = n === 0;
    btn.textContent = n === 0
        ? btn.dataset.labelNone
        : btn.dataset.labelSelected.replace('__N__', n);

    // Hide the open-panel whenever selection changes
    document.getElementById('open-panel-' + idx).style.display = 'none';
}

function toggleSelectAll(idx, checked) {
    document.querySelectorAll('.file-cb[data-edition="' + idx + '"]').forEach(cb => cb.checked = checked);
    onFileCheck(idx);
}

async function downloadZip(idx) {
    const checked = getChecked(idx);
    if (!checked.length) return;

    if (IMSLP_CREDENTIALS) {
        const card     = document.getElementById('edition-' + idx);
        const btn      = document.getElementById('dlBtn-' + idx);
        const fill     = document.getElementById('dl-fill-' + idx);
        const label    = document.getElementById('dl-label-' + idx);
        const progress = document.getElementById('dl-progress-' + idx);
        const zipName  = card.dataset.zipname || 'imslp-download';

        // Generate a job ID so the progress endpoint can find our progress file
        const jobId = Math.random().toString(36).slice(2, 18).replace(/[^a-z0-9]/g, '0');

        btn.disabled    = true;
        btn.textContent = 'Downloading…';
        progress.style.display = 'block';
        fill.style.width = '0%';
        label.textContent = '';

        const formData = new FormData();
        checked.forEach(cb => formData.append('files[]', cb.dataset.filename));
        formData.append('zipName', zipName);
        formData.append('jobId', jobId);

        // Poll progress while the download request runs
        const total = checked.length;
        const poller = setInterval(async () => {
            try {
                const p = await fetch('/imslp/download-progress/' + jobId);
                if (!p.ok) return;
                const d = await p.json();
                if (d.total > 0) {
                    const pct = Math.round(d.done / d.total * 100);
                    fill.style.width = pct + '%';
                    label.textContent = d.current
                        ? `${d.done + 1}/${d.total}  ${d.current}`
                        : `${d.done}/${d.total}`;
                }
            } catch (_) {}
        }, 500);

        try {
            const resp = await fetch('/imslp/download-zip', { method: 'POST', body: formData });
            clearInterval(poller);
            fill.style.width = '100%';
            if (!resp.ok) {
                const err = await resp.json().catch(() => ({}));
                throw new Error(err.error || 'Server error ' + resp.status);
            }
            label.textContent = 'Preparing ZIP…';
            const blob = await resp.blob();
            const a = Object.assign(document.createElement('a'), {
                href: URL.createObjectURL(blob),
                download: zipName + '.zip',
            });
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(a.href);
        } catch (err) {
            clearInterval(poller);
            alert('Download failed: ' + err.message);
        }

        progress.style.display = 'none';
        onFileCheck(idx);
        return;
    }

    // No server credentials — open tabs in the browser.
    // window.open returns null when blocked; show a panel for those.
    const blocked = [];
    checked.forEach(cb => {
        const w = window.open(
            IMSLP_BASE + encodeURIComponent(cb.dataset.filename),
            '_blank', 'noopener noreferrer'
        );
        if (!w) blocked.push(cb);
    });

    const panel = document.getElementById('open-panel-' + idx);
    if (blocked.length === 0) { panel.style.display = 'none'; return; }

    const list = document.getElementById('open-panel-list-' + idx);
    list.innerHTML = '';
    blocked.forEach(cb => {
        const li = document.createElement('li');
        const a  = document.createElement('a');
        a.href        = IMSLP_BASE + encodeURIComponent(cb.dataset.filename);
        a.target      = '_blank';
        a.rel         = 'noopener noreferrer';
        a.textContent = cb.dataset.filename;
        a.className   = 'files-open-link';
        li.appendChild(a);
        list.appendChild(li);
    });
    panel.style.display = 'block';
}

// ── Stagger-animate sections on page load ──
(function () {
    function anim(sel, delay) {
        document.querySelectorAll(sel).forEach((el, i) => {
            el.classList.add('anim-fade-up');
            el.style.animationDelay = (delay + i * 45) + 'ms';
        });
    }
    anim('.work-header',    0);
    anim('.ext-links',     60);
    anim('.notice',        80);
    anim('.meta-grid',    100);
    anim('.section-title', 150);
    anim('.edition-card',  180);
})();
</script>

</div>
{% endblock %}
