{% extends 'base.html.twig' %}

{% block title %}{{ work.title }} — IMSLP{% endblock %}

{% block head %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
    background: #1a1a1a;
    color: #e8e0d4;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    min-height: 100vh;
}
.wrapper {
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
}
.back-link {
    display: inline-block;
    color: #c8a96e;
    text-decoration: none;
    font-size: .85rem;
    margin-bottom: 1.5rem;
}
.back-link:hover { text-decoration: underline; }

/* ── Work header ── */
.work-header {
    margin-bottom: 2rem;
}
.work-header h1 {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    color: #f0e6c8;
    line-height: 1.25;
    margin-bottom: .4rem;
}
.work-header .composer-line {
    font-size: 1.1rem;
    color: #c8a96e;
    margin-bottom: .8rem;
}
.work-header .catalog-no {
    font-size: .85rem;
    color: #8a8070;
}

/* ── Metadata grid ── */
.meta-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .6rem 2rem;
    background: #252525;
    border: 1px solid #333;
    border-radius: 10px;
    padding: 1.4rem 1.6rem;
    margin-bottom: 2rem;
}
@media (max-width: 600px) { .meta-grid { grid-template-columns: 1fr; } }
.meta-item {}
.meta-item dt {
    font-size: .72rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: #6a6058;
    margin-bottom: .15rem;
}
.meta-item dd {
    font-size: .9rem;
    color: #d8d0c4;
}

/* ── Files / Editions section ── */
.section-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    color: #f0e6c8;
    margin-bottom: 1rem;
    padding-bottom: .5rem;
    border-bottom: 1px solid #2e2e2e;
}

/* Edition card (one per #fte:imslpfile block) */
.edition-card {
    background: #222;
    border: 1px solid #333;
    border-radius: 10px;
    margin-bottom: .9rem;
    overflow: hidden;
}
.edition-header {
    padding: .75rem 1.1rem;
    background: #252525;
    border-bottom: 1px solid #2e2e2e;
}
.edition-title {
    font-size: .92rem;
    color: #d8d0c4;
    font-weight: 500;
    margin-bottom: .25rem;
}
.edition-title em { color: #c8a96e; font-style: normal; }
.edition-meta {
    font-size: .75rem;
    color: #6a6058;
    display: flex;
    flex-wrap: wrap;
    gap: .3rem .9rem;
}
.edition-meta .copyright { color: #8a8070; }

/* File rows inside an edition */
.edition-files {
    display: flex;
    flex-direction: column;
}
.file-row {
    display: flex;
    align-items: baseline;
    gap: .6rem;
    padding: .45rem 1.1rem;
    border-bottom: 1px solid #1e1e1e;
}
.file-row:last-child { border-bottom: none; }
.file-desc {
    font-size: .88rem;
    color: #d8d0c4;
    flex: 1 1 auto;
}
.file-name {
    font-family: monospace;
    font-size: .75rem;
    color: #6a6058;
    flex: 0 1 auto;
    word-break: break-all;
    text-align: right;
}

/* ── IMSLP link ── */
.imslp-link {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    background: #c8a96e;
    color: #1a1a1a;
    text-decoration: none;
    padding: .6rem 1.2rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: .9rem;
    transition: background .2s;
    margin-bottom: 2rem;
}
.imslp-link:hover { background: #d9be88; }

/* ── Movements list ── */
.movements-list {
    margin: .4rem 0 0 0;
    padding: 0;
    list-style: none;
    font-size: .88rem;
    color: #d8d0c4;
    line-height: 1.7;
    counter-reset: mvt;
}
.movements-header {
    font-size: .78rem;
    text-transform: uppercase;
    letter-spacing: .07em;
    color: #6a6058;
    margin-top: .6rem;
    margin-bottom: .1rem;
    padding-left: 0;
}
.movements-header:first-child { margin-top: 0; }
.movements-subheader {
    font-size: .85rem;
    color: #c8a96e;
    margin-top: .7rem;
    margin-bottom: .1rem;
    padding-left: .8rem;
    counter-reset: mvt;
    font-style: italic;
}
.movements-subheader:first-child { margin-top: 0; }
.movements-item {
    counter-increment: mvt;
    padding-left: 2.4rem;
    position: relative;
}
.movements-item::before {
    content: counter(mvt) ".";
    position: absolute;
    left: 0;
    color: #6a6058;
    font-size: .8rem;
    min-width: 2rem;
    text-align: right;
}

/* ── No detail notice ── */
.notice {
    background: #2a2520;
    border: 1px solid #3a3020;
    border-radius: 8px;
    padding: 1rem 1.2rem;
    font-size: .85rem;
    color: #9a8878;
    margin-bottom: 1.5rem;
}
</style>
{% endblock %}

{% block body %}
<div class="wrapper">

    <a class="back-link" href="javascript:history.back()">← Back to search</a>

    <div class="work-header">
        <h1>{{ work.title }}</h1>
        <div class="composer-line">{{ work.composer }}</div>
        {% if work.catalogNumber %}
        <div class="catalog-no">{{ work.catalogNumber }}</div>
        {% endif %}
    </div>

    <a class="imslp-link" href="{{ work.permlink }}" target="_blank" rel="noopener">
        Open on IMSLP ↗
    </a>

    {% if not work.hasDetail() %}
    <div class="notice">
        Detail data (instrumentation, files) has not been fetched yet for this work.
        Run <code>php bin/console app:imslp:fetch-details</code> to populate it,
        or visit the IMSLP page directly.
    </div>
    {% endif %}

    <!-- Metadata -->
    {% if work.hasDetail() %}
    <dl class="meta-grid">
        {% if work.workKey %}
        <div class="meta-item"><dt>Key</dt><dd>{{ work.workKey }}</dd></div>
        {% endif %}
        {% if work.instrumentation %}
        <div class="meta-item"><dt>Instrumentation</dt><dd>{{ work.instrumentation }}</dd></div>
        {% endif %}
        {% if work.pieceStyle %}
        <div class="meta-item"><dt>Style</dt><dd>{{ work.pieceStyle }}</dd></div>
        {% endif %}
        {% if work.yearComposed %}
        <div class="meta-item"><dt>Year composed</dt><dd>{{ work.yearComposed }}</dd></div>
        {% endif %}
        {% if work.yearPublished %}
        <div class="meta-item"><dt>Year published</dt><dd>{{ work.yearPublished }}</dd></div>
        {% endif %}
        {% if work.pageType %}
        <div class="meta-item"><dt>Type</dt><dd>{{ work.pageType }}</dd></div>
        {% endif %}
        {% if work.movements %}
        <div class="meta-item" style="grid-column:1/-1">
            <dt>Movements / Sections</dt>
            <dd>
                <ul class="movements-list">
                {% for line in work.movements|split('\n') %}
                    {% set line = line|trim %}
                    {% if line %}
                        {% if line ends with ':' %}
                            <li class="movements-header">{{ line|trim(':') }}</li>
                        {% elseif
                            ', TWV' in line or ', BWV' in line or ', HWV' in line or
                            ', RV'  in line or ', Op.' in line or ', op.' in line or
                            ', KV'  in line or ', K.'  in line or ', Wq'  in line or
                            ', WoO' in line or ', D.'  in line or ', L.'  in line or
                            ', Z.'  in line or ', H.'  in line or ', TH'  in line or
                            ', CT'  in line or ', T.'  in line or ', P.'  in line or
                            'No. '  in line or 'Nr. '  in line
                        %}
                            <li class="movements-subheader">{{ line }}</li>
                        {% else %}
                            <li class="movements-item">{{ line }}</li>
                        {% endif %}
                    {% endif %}
                {% endfor %}
                </ul>
            </dd>
        </div>
        {% endif %}
        {% if work.tags %}
        <div class="meta-item" style="grid-column:1/-1"><dt>Tags</dt><dd>{{ work.tags }}</dd></div>
        {% endif %}
    </dl>
    {% endif %}

    <!-- Files / Editions -->
    {% if work.filesJson is not empty %}
    {# Detect format: new = array of editions (each has a 'files' key);
       old = flat array of file objects (each has a 'filename' key directly) #}
    {% set isEditionFormat = work.filesJson[0] is defined and work.filesJson[0].files is defined %}

    {% if isEditionFormat %}
        {# Count total files across all editions #}
        {% set totalFiles = 0 %}
        {% for ed in work.filesJson %}{% set totalFiles = totalFiles + ed.files|length %}{% endfor %}
        <h2 class="section-title">Score files — {{ work.filesJson|length }} edition{{ work.filesJson|length != 1 ? 's' : '' }}, {{ totalFiles }} file{{ totalFiles != 1 ? 's' : '' }}</h2>

        {% for ed in work.filesJson %}
        <div class="edition-card">
            <div class="edition-header">
                <div class="edition-title">
                    {% if ed.editor is defined and ed.editor %}
                        Ed. <em>{{ ed.editor }}</em>{% if ed.publisher is defined and ed.publisher %} — {{ ed.publisher }}{% endif %}
                    {% elseif ed.arranger is defined and ed.arranger %}
                        Arr. <em>{{ ed.arranger }}</em>{% if ed.publisher is defined and ed.publisher %} — {{ ed.publisher }}{% endif %}
                    {% elseif ed.publisher is defined and ed.publisher %}
                        {{ ed.publisher }}
                    {% else %}
                        <span style="color:#6a6058;font-style:italic">Anonymous edition</span>
                    {% endif %}
                </div>
                <div class="edition-meta">
                    {% if ed.dateSubmitted is defined and ed.dateSubmitted %}
                    <span>Submitted {{ ed.dateSubmitted }}</span>
                    {% endif %}
                    {% if ed.copyright is defined and ed.copyright %}
                    <span class="copyright">{{ ed.copyright }}</span>
                    {% endif %}
                </div>
            </div>
            <div class="edition-files">
                {% for file in ed.files %}
                <div class="file-row">
                    <div class="file-desc">{{ file.description is defined and file.description ? file.description : file.filename }}</div>
                    {% if file.description is defined and file.description %}
                    <div class="file-name">{{ file.filename }}</div>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
        </div>
        {% endfor %}

    {% else %}
        {# Legacy flat format — render as before #}
        <h2 class="section-title">Score files ({{ work.filesJson|length }})</h2>
        {% for file in work.filesJson %}
        <div class="edition-card">
            <div class="edition-header">
                <div class="edition-meta">
                    {% if file.editor is defined and file.editor %}<span>Ed. {{ file.editor }}</span>{% endif %}
                    {% if file.publisher is defined and file.publisher %}<span>{{ file.publisher }}</span>{% endif %}
                    {% if file.copyright is defined and file.copyright %}<span class="copyright">{{ file.copyright }}</span>{% endif %}
                </div>
            </div>
            <div class="edition-files">
                <div class="file-row">
                    <div class="file-desc">{{ file.description is defined and file.description ? file.description : file.filename }}</div>
                    <div class="file-name">{{ file.filename }}</div>
                </div>
            </div>
        </div>
        {% endfor %}
    {% endif %}

    <p style="font-size:.8rem;color:#6a6058;margin-bottom:2rem;margin-top:.5rem;">
        Download PDF files directly from the
        <a href="{{ work.permlink }}" target="_blank" rel="noopener" style="color:#c8a96e">IMSLP work page</a>.
    </p>
    {% endif %}

</div>
{% endblock %}
