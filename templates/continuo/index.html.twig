{% extends 'base.html.twig' %}

{% block title %}Basso Continuo Realizer{% endblock %}

{% block head %}
<!-- Google Fonts: Playfair Display + Inter -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/base.css">
<link rel="stylesheet" href="/css/header.css">
<link rel="stylesheet" href="/css/card.css">
<link rel="stylesheet" href="/css/result.css">
<link rel="stylesheet" href="/css/accordion.css">
<link rel="stylesheet" href="/css/score.css">
<link rel="stylesheet" href="/css/bass-editor.css">
<link rel="stylesheet" href="/css/chord-inspector.css">
<link rel="stylesheet" href="/css/playback.css">
<link rel="stylesheet" href="/css/layout.css">
{% endblock %}

{% block body %}
<div class="wrapper">

    <!-- Header -->
    <header class="site-header">
        <p class="subtitle">{{ 'app.subtitle'|trans }}</p>
        <h1>{{ 'app.title'|trans }}</h1>
        <div class="staff-deco">
            <div class="line"></div>
            <span class="clef">𝄢</span>
            <div class="line"></div>
        </div>
        <p class="desc">{{ 'app.desc'|trans }}</p>
    </header>

    <!-- Input card: Compose / Import tabs -->
    <div class="card" id="input-card">

        <div class="input-tabs" id="input-tabs">
            <div class="input-tab active" data-pane="pane-compose">♩ Enter notes</div>
            <div class="input-tab"        data-pane="pane-import">⬆ Import</div>
        </div>

        <!-- ── Compose pane (speedy entry) ── -->
        <div class="input-pane active" id="pane-compose">
            <div class="ed-toolbar">
                <div class="ed-ctrl-group">
                    <label>Key</label>
                    <select class="ed-ctrl-select" id="ed-key">
                        <option value="-7">C♭ / A♭m</option>
                        <option value="-6">G♭ / E♭m</option>
                        <option value="-5">D♭ / B♭m</option>
                        <option value="-4">A♭ / Fm</option>
                        <option value="-3">E♭ / Cm</option>
                        <option value="-2">B♭ / Gm</option>
                        <option value="-1">F / Dm</option>
                        <option value="0" selected>C / Am</option>
                        <option value="1">G / Em</option>
                        <option value="2">D / Bm</option>
                        <option value="3">A / F♯m</option>
                        <option value="4">E / C♯m</option>
                        <option value="5">B / G♯m</option>
                        <option value="6">F♯ / D♯m</option>
                        <option value="7">C♯ / A♯m</option>
                    </select>
                </div>
                <div class="ed-ctrl-group">
                    <label>Time</label>
                    <select class="ed-ctrl-select" id="ed-time">
                        <option value="4/4" selected>4/4</option>
                        <option value="3/4">3/4</option>
                        <option value="2/4">2/4</option>
                        <option value="2/2">2/2 (¢)</option>
                        <option value="6/8">6/8</option>
                        <option value="3/8">3/8</option>
                    </select>
                </div>
                <button class="ed-realize-btn" id="ed-realize-btn" disabled>♩ Realize</button>
            </div>
            <div class="ed-dur-bar">
                <span class="ed-dur-lbl">Dur:</span>
                <button class="ed-dur-btn" data-dur="whole"   title="Whole (key 7)">W</button>
                <button class="ed-dur-btn" data-dur="half"    title="Half (key 6)">H</button>
                <button class="ed-dur-btn ed-active" data-dur="quarter" title="Quarter (key 5)">Q</button>
                <button class="ed-dur-btn" data-dur="eighth"  title="Eighth (key 4)">8</button>
                <button class="ed-dur-btn" data-dur="16th"    title="16th (key 3)">16</button>
                <button class="ed-dot-btn" id="ed-dot-btn"    title="Dotted (key .)">·</button>
                <span style="width:.5rem"></span>
                <button class="ed-dur-btn ed-acc-btn" id="ed-flat-btn"    data-acc="-1" title="Flat prefix (key -)">♭</button>
                <button class="ed-dur-btn ed-acc-btn" id="ed-natural-btn" data-acc="0"  title="Natural prefix (key =)">♮</button>
                <button class="ed-dur-btn ed-acc-btn" id="ed-sharp-btn"   data-acc="1"  title="Sharp prefix (key +)">♯</button>
                <span class="ed-acc-display" id="ed-acc-display"></span>
            </div>
            <div class="score-wrap" id="ed-score-wrap" tabindex="0" style="min-height:280px;outline:none;cursor:text">
                <div class="score-placeholder"><div class="spinner" style="width:22px;height:22px;border-width:2px"></div></div>
            </div>
            <div class="ed-fig-bar">
                <span>Figures for selected note</span>
                <span style="color:var(--muted);font-size:0.73rem;margin-left:.25rem">(Tab)</span>
                <span style="flex:1"></span>
                <input type="text" class="ed-fig-input" id="ed-fig-input"
                       placeholder="7,s" autocomplete="off" spellcheck="false">
                <button class="ed-fig-btn" id="ed-fig-set" title="Apply (Enter)">✓</button>
                <span class="ed-fig-preview" id="ed-fig-preview"></span>
            </div>
            <div class="ed-status" id="ed-status"></div>
            <div class="ed-help">
                <div class="ed-help-row">
                    <span><kbd>↑</kbd><kbd>↓</kbd> pitch &nbsp;<kbd>⇧↑↓</kbd> octave</span>
                    <span><kbd>7</kbd> whole &nbsp;<kbd>6</kbd> half &nbsp;<kbd>5</kbd> quarter &nbsp;<kbd>4</kbd> 8th &nbsp;<kbd>3</kbd> 16th</span>
                    <span><kbd>.</kbd> dot &nbsp;<kbd>R</kbd> rest &nbsp;<kbd>=</kbd> tie</span>
                    <span><kbd>-</kbd> ♭ &nbsp;<kbd>*</kbd> ♮ &nbsp;<kbd>+</kbd> ♯</span>
                    <span><kbd>←</kbd><kbd>→</kbd> navigate &nbsp;<kbd>⌫</kbd> delete</span>
                    <span><kbd>Tab</kbd> figures</span>
                </div>
            </div>
        </div>

        <!-- ── Import pane (file upload) ── -->
        <div class="input-pane" id="pane-import">
            <div class="import-body">
                {% if error is defined and error %}
                <div class="alert alert-error">
                    <span>⚠</span>
                    <span>{{ error }}</span>
                </div>
                {% endif %}

                <form id="upload-form" action="{{ path('app_realize_preview') }}" method="post" enctype="multipart/form-data">
                    <div class="drop-zone" id="drop-zone">
                        <input type="file" name="musicxml" id="file-input" accept=".xml,.musicxml,.mxl">
                        <span class="icon">𝄞</span>
                        <div class="label">{{ 'upload.drop_label'|trans }}</div>
                        <div class="hint">{{ 'upload.drop_hint'|trans }}</div>
                    </div>
                    <div class="file-name" id="file-name-display">
                        <span>📄</span>
                        <span id="file-name-text"></span>
                    </div>

                    <div class="btn-row">
                        <button type="submit" class="btn btn-primary" id="realize-btn" disabled>
                            <span>♩</span>
                            {{ 'upload.realize_btn'|trans }}
                        </button>
                        <button type="button" class="btn btn-secondary" id="clear-btn" style="display:none">
                            {{ 'upload.clear_btn'|trans }}
                        </button>
                        <button type="button" class="btn btn-params" id="params-btn" aria-expanded="false" aria-controls="params-panel">
                            ⚙ {{ 'params.btn'|trans }}
                        </button>
                        <span id="sample-hint" style="font-size:0.82rem;color:var(--muted);margin-left:0.25rem">
                            &larr; or
                            <a href="#" id="load-sample-btn"
                               style="color:var(--accent);text-decoration:none;font-weight:500">
                               {{ 'upload.sample_hint'|trans }}
                            </a>
                        </span>
                    </div>

                    <!-- Params panel (collapsed by default) -->
                    <div class="params-panel" id="params-panel" style="display:none">
                        <fieldset class="params-fieldset">
                            <legend class="params-legend">{{ 'params.voices_label'|trans }}</legend>
                            <label class="params-radio">
                                <input type="radio" name="voices" value="4" checked>
                                {{ 'params.voices_4'|trans }}
                            </label>
                            <label class="params-radio">
                                <input type="radio" name="voices" value="3">
                                {{ 'params.voices_3'|trans }}
                            </label>
                        </fieldset>
                    </div>
                </form>
            </div>
        </div>

        <!-- Spinner (shared between both panes) -->
        <div class="progress-wrap" id="progress-wrap">
            <div class="spinner"></div>
            <p class="progress-text">{{ 'upload.progress'|trans }}</p>
        </div>

    </div>

    <!-- Result Panel -->
    <div id="result-panel">
        <div class="card">
            <div class="card-title">{{ 'result.card_title'|trans }}</div>

            <div class="alert alert-success" id="success-msg">
                <span>✓</span>
                <span>{{ 'result.success_msg'|trans }}</span>
            </div>

            <!-- Summary grid -->
            <div class="summary-grid" id="summary-grid">
                <!-- populated by JS -->
            </div>

            <!-- Top chords -->
            <div id="chord-section" style="display:none">
                <p style="font-size:0.82rem;color:var(--muted);text-transform:uppercase;letter-spacing:.06em;margin-bottom:.4rem">{{ 'result.top_chords'|trans }}</p>
                <div class="chord-pills" id="chord-pills"></div>
            </div>

            <!-- XML preview -->
            <div>
                <p style="font-size:0.82rem;color:var(--muted);margin-top:1rem;text-transform:uppercase;letter-spacing:.06em">{{ 'result.output_preview'|trans }}</p>
                <div class="xml-preview" id="xml-preview"></div>
            </div>

            <!-- Actions -->
            <div class="btn-row">
                <button class="btn btn-dl" id="download-btn">
                    ⬇ {{ 'result.download_btn'|trans }}
                </button>
                <button class="btn btn-secondary" id="new-btn">
                    ↩ {{ 'result.new_btn'|trans }}
                </button>
            </div>
        </div>

        <!-- Score Viewer Card -->
        <div class="card" id="score-viewer-card" style="display:none">
            <div class="card-title">{{ 'viewer.card_title'|trans }}</div>

            <div class="score-tabs">
                <div class="score-tab active" data-pane="pane-orig">{{ 'viewer.tab_orig'|trans }}</div>
                <div class="score-tab"        data-pane="pane-real">{{ 'viewer.tab_real'|trans }}</div>
            </div>

            <!-- Playback bar (shown once a score is loaded) -->
            <div class="playback-bar" id="playback-bar" style="display:none">
                <button id="pb-play" class="pb-btn" title="Play" disabled>▶</button>
                <button id="pb-stop" class="pb-btn" title="Stop" disabled>⏹</button>
                <div class="pb-progress" id="pb-progress">
                    <div class="pb-progress-fill" id="pb-fill"></div>
                </div>
                <span class="pb-time" id="pb-time">0:00</span>
                <span class="pb-loading" id="pb-loading" style="display:none">⟳ loading…</span>

                <!-- Speed knob — symmetric log₄ scale: ×0.25 … ×1.0 … ×4.0 -->
                <div class="pb-knob-wrap" id="pb-spd-wrap"
                     title="Playback speed — drag up/down or scroll · double-click to reset">
                    <svg class="pb-knob" viewBox="0 0 40 40" width="38" height="38">
                        <path class="pb-knob-track" d="M 9.39 30.61 A 15 15 0 1 1 30.61 30.61"/>
                        <path class="pb-knob-fill"  id="pb-spd-fill" d=""/>
                        <line class="pb-knob-notch" id="pb-spd-notch" x1="20" y1="16" x2="20" y2="7"/>
                        <circle class="pb-knob-dot" cx="20" cy="20" r="2.5"/>
                    </svg>
                    <div class="pb-knob-lbl">Speed<b id="pb-spd-val">×1.00</b></div>
                </div>

                <!-- Pitch knob — ±12 semitones, centred at 0 -->
                <div class="pb-knob-wrap" id="pb-pit-wrap"
                     title="Pitch offset (semitones) — drag up/down or scroll · double-click to reset">
                    <svg class="pb-knob" viewBox="0 0 40 40" width="38" height="38">
                        <path class="pb-knob-track" d="M 9.39 30.61 A 15 15 0 1 1 30.61 30.61"/>
                        <path class="pb-knob-fill"  id="pb-pit-fill" d=""/>
                        <line class="pb-knob-notch" id="pb-pit-notch" x1="20" y1="16" x2="20" y2="7"/>
                        <circle class="pb-knob-dot" cx="20" cy="20" r="2.5"/>
                    </svg>
                    <div class="pb-knob-lbl">Pitch<b id="pb-pit-val">±0</b></div>
                </div>
            </div>

            <!-- Original pane -->
            <div class="score-pane active" id="pane-orig">
                <div class="page-nav" id="nav-orig" style="display:none">
                    <button class="page-nav-btn" id="prev-orig" disabled>&#8592;</button>
                    <span id="lbl-orig">1 / 1</span>
                    <button class="page-nav-btn" id="next-orig" disabled>&#8594;</button>
                </div>
                <div class="score-wrap" id="wrap-orig">
                    <div class="score-placeholder">
                        <div class="spinner" style="width:28px;height:28px;border-width:2px"></div>
                        <span>{{ 'viewer.waiting'|trans }}</span>
                    </div>
                </div>
            </div>

            <!-- Realization pane -->
            <div class="score-pane" id="pane-real">
                <p id="click-hint" style="display:none;font-size:0.78rem;color:var(--muted);text-align:center;margin-bottom:0.5rem">
                    {{ 'viewer.click_hint'|trans }}
                </p>
                <div class="real-toolbar">
                    <label class="cb-label">
                        <input type="checkbox" id="cb-show-computed">
                        {{ 'viewer.show_computed'|trans }}
                        <span class="cb-swatch"></span>
                    </label>
                </div>
                <div class="page-nav" id="nav-real" style="display:none">
                    <button class="page-nav-btn" id="prev-real" disabled>&#8592;</button>
                    <span id="lbl-real">1 / 1</span>
                    <button class="page-nav-btn" id="next-real" disabled>&#8594;</button>
                </div>
                <div class="score-wrap" id="wrap-real">
                    <div class="score-placeholder">
                        <div class="spinner" style="width:28px;height:28px;border-width:2px"></div>
                        <span>{{ 'viewer.waiting'|trans }}</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Accordion: How it works -->
    <details class="accordion">
        <summary class="accordion-header">
            <span>{{ 'how_it_works.heading'|trans }}</span>
            <span class="accordion-chevron">▼</span>
        </summary>
        <div class="accordion-body">
            <h4>{{ 'how_it_works.algo_heading'|trans }}</h4>
            <p>{{ 'how_it_works.algo_intro'|trans }}</p>
            <ul>
                <li><strong>Francesco Gasparini</strong> — <em>{{ 'how_it_works.algo_gasparini'|trans }}</em></li>
                <li><strong>Denis Delair</strong> — <em>{{ 'how_it_works.algo_delair'|trans }}</em></li>
            </ul>

            <h4>{{ 'how_it_works.pipeline_heading'|trans }}</h4>
            <ul>
                <li><strong>1.</strong> {{ 'how_it_works.step1'|trans }}</li>
                <li><strong>2.</strong> {{ 'how_it_works.step2'|trans }}</li>
                <li><strong>3.</strong> {{ 'how_it_works.step3'|trans }}
                    <ul>
                        <li>{{ 'how_it_works.step3_a'|trans }}</li>
                        <li>{{ 'how_it_works.step3_b'|trans }}</li>
                        <li>{{ 'how_it_works.step3_c'|trans }}</li>
                        <li>{{ 'how_it_works.step3_d'|trans }}</li>
                        <li>{{ 'how_it_works.step3_e'|trans }}</li>
                    </ul>
                </li>
                <li><strong>4.</strong> {{ 'how_it_works.step4'|trans }}</li>
                <li><strong>5.</strong> {{ 'how_it_works.step5'|trans }}
                    <ul>
                        <li>{{ 'how_it_works.step5_a'|trans }}</li>
                        <li>{{ 'how_it_works.step5_b'|trans }}</li>
                        <li>{{ 'how_it_works.step5_c'|trans }}</li>
                    </ul>
                </li>
                <li><strong>6.</strong> {{ 'how_it_works.step6'|trans }}</li>
            </ul>

            <h4>{{ 'how_it_works.fb_heading'|trans }}</h4>
            <table class="fb-ref">
              <tbody>
                <tr class="fb-sec"><td colspan="3">{{ 'how_it_works.fb_sec_triads'|trans }}</td></tr>
                <tr><td>(none) / 5</td><td class="fb-int">5</td><td>{{ 'how_it_works.fb_none'|trans }}</td></tr>
                <tr><td>6</td><td class="fb-int">6</td><td>{{ 'how_it_works.fb_6'|trans }}</td></tr>
                <tr><td>6 4</td><td class="fb-int">6 4</td><td>{{ 'how_it_works.fb_64'|trans }}</td></tr>
                <tr class="fb-sec"><td colspan="3">{{ 'how_it_works.fb_sec_sevenths'|trans }}</td></tr>
                <tr><td>7</td><td class="fb-int">7 5</td><td>{{ 'how_it_works.fb_7'|trans }}</td></tr>
                <tr><td>6 5</td><td class="fb-int">6 5</td><td>{{ 'how_it_works.fb_65'|trans }}</td></tr>
                <tr><td>♭5</td><td class="fb-int">♭5 6</td><td>{{ 'how_it_works.fb_b5'|trans }}</td></tr>
                <tr><td>4 3</td><td class="fb-int">4 3</td><td>{{ 'how_it_works.fb_43'|trans }}</td></tr>
                <tr><td>2 <small>(= 4 2)</small></td><td class="fb-int">4 2</td><td>{{ 'how_it_works.fb_2'|trans }}</td></tr>
                <tr><td>♯4</td><td class="fb-int">♯4 2</td><td>{{ 'how_it_works.fb_sharp4'|trans }}</td></tr>
                <tr class="fb-sec"><td colspan="3">{{ 'how_it_works.fb_sec_ninths'|trans }}</td></tr>
                <tr><td>9</td><td class="fb-int">9 5</td><td>{{ 'how_it_works.fb_9'|trans }}</td></tr>
                <tr><td>9 7</td><td class="fb-int">9 7 5</td><td>{{ 'how_it_works.fb_97'|trans }}</td></tr>
                <tr class="fb-sec"><td colspan="3">{{ 'how_it_works.fb_sec_suspensions'|trans }}</td></tr>
                <tr><td>7 6</td><td class="fb-int">7 6</td><td>{{ 'how_it_works.fb_76'|trans }}</td></tr>
                <tr><td>5 4</td><td class="fb-int">5 4</td><td>{{ 'how_it_works.fb_54'|trans }}</td></tr>
                <tr class="fb-sec"><td colspan="3">{{ 'how_it_works.fb_sec_chromatic'|trans }}</td></tr>
                <tr><td>♯5</td><td class="fb-int">♯5 7 9</td><td>{{ 'how_it_works.fb_sharp5'|trans }}</td></tr>
                <tr><td>♭7</td><td class="fb-int">♭7 5</td><td>{{ 'how_it_works.fb_b7'|trans }}</td></tr>
                <tr class="fb-sec"><td colspan="3">{{ 'how_it_works.fb_sec_special'|trans }}</td></tr>
                <tr><td>8</td><td class="fb-int">8</td><td>{{ 'how_it_works.fb_8'|trans }}</td></tr>
                <tr><td>♯ / ♭ / ♮</td><td class="fb-int"></td><td>{{ 'how_it_works.fb_acc'|trans }}</td></tr>
              </tbody>
            </table>
        </div>
    </details>

    <!-- Accordion: Bibliography -->
    <details class="accordion" style="margin-top:1rem">
        <summary class="accordion-header">
            <span>{{ 'bibliography.heading'|trans }}</span>
            <span class="accordion-chevron">▼</span>
        </summary>
        <div class="accordion-body">
            <ul>
                <li><strong>Gasparini, F.</strong> (1729). <em><a href="https://imslp.org/wiki/L%27Armonico_Pratico_al_Cimbalo_(Gasparini%2C_Francesco)" target="_blank" rel="noopener">L'Armonico Pratico al Cimbalo</a></em>. 3rd ed. Venice. [Trans. F. Stillings, 1963. Yale University Press.]</li>
                <li><strong>St. Lambert, M. de</strong> (1707). <em><a href="https://imslp.org/wiki/Nouveau_trait%C3%A9_de_l%27accompagnement_(Saint-Lambert%2C_Michel_de)" target="_blank" rel="noopener">Nouveau Traité de l'Accompagnement du Clavecin, de l'Orgue et des autres Instruments</a></em>. Paris: Ballard.</li>
                <li><strong>Delair, D.</strong> (1690). <em><a href="https://gallica.bnf.fr/ark:/12148/bpt6k324883j" target="_blank" rel="noopener">Traité d'Accompagnement pour le Théorbe et le Clavecin</a></em>. Paris. <small>(via Gallica)</small></li>
                <li><strong>Heinichen, J.D.</strong> (1728). <em><a href="https://imslp.org/wiki/Der_General-Bass_in_der_Composition_(Heinichen%2C_Johann_David)" target="_blank" rel="noopener">Der General-Bass in der Composition</a></em>. Dresden.</li>
                <li><strong>Fux, J.J.</strong> (1725). <em><a href="https://imslp.org/wiki/Gradus_ad_Parnassum_(Fux%2C_Johann_Joseph)" target="_blank" rel="noopener">Gradus ad Parnassum</a></em>. Vienna. [Trans. A. Mann, 1943. Norton.]</li>
                <li><strong>Rameau, J.-P.</strong> (1722). <em><a href="https://imslp.org/wiki/Trait%C3%A9_de_l%27harmonie_r%C3%A9duite_%C3%A0_ses_principes_naturels_(Rameau%2C_Jean-Philippe)" target="_blank" rel="noopener">Traité de l'harmonie réduite à ses principes naturels</a></em>. Paris.</li>
                <li><strong>Telemann, G.M.</strong> (1773). <em><a href="https://imslp.org/wiki/Unterricht_im_Generalba%C3%9F-Spielen_(Telemann%2C_Georg_Michael)" target="_blank" rel="noopener">Unterricht im Generalbaß-Spielen</a></em>. Hamburg: M.C. Bock. [Quoted in T. Christensen 1992.]</li>
                <li><strong>Christensen, T.</strong> (1992). "<a href="https://www.jstor.org/stable/932911" target="_blank" rel="noopener">The <em>Règle de l'octave</em> in Thorough-Bass Theory and Practice</a>." <em>Acta Musicologica</em>, 64/2, pp. 112–145.</li>
                <li><strong>Christensen, J.B.</strong> (2002). <em><a href="https://openlibrary.org/works/OL6084240W" target="_blank" rel="noopener">18th Century Continuo Playing: A Historical Guide to the Basics</a></em>. Kassel: Bärenreiter.</li>
                <li><strong>Wead, A. &amp; Knopke, I.</strong> (2007). "<a href="https://docs.google.com/viewer?url=https%3A%2F%2Fquod.lib.umich.edu%2Fcgi%2Fp%2Fpod%2Fdod-idx%2Fa-computer-based-implementation-of-basso-continuo-rules.pdf%3Fc%3Dicmc%3Bidno%3Dbbp2372.2007.150" target="_blank" rel="noopener">A Computer-Based Implementation of Basso Continuo Rules for Figured Bass Realizations</a>." <em>Proceedings of the International Computer Music Conference (ICMC)</em>, Copenhagen.</li>
            </ul>
        </div>
    </details>

    <!-- Accordion: Voice Leading Rules -->
    <details class="accordion" style="margin-top:1rem">
        <summary class="accordion-header">
            <span>Voice Leading Rules ({{ rules|length }})</span>
            <span class="accordion-chevron">▼</span>
        </summary>
        <div class="accordion-body">
            <div class="rules-list">
            {% for rule in rules %}
                <details class="rule-card">
                    <summary>
                        <div class="rule-card-left">
                            <span class="rule-name">{{ rule.name|replace({'_': ' '})|title }}</span>
                            <span class="rule-source">{{ rule.source }}</span>
                        </div>
                        <div class="rule-card-right">
                            <span class="rule-priority">P{{ rule.priority }}</span>
                            <span class="rule-badge {% if rule.enabled %}rule-enabled{% else %}rule-disabled{% endif %}">
                                {{ rule.enabled ? 'enabled' : 'disabled' }}
                            </span>
                        </div>
                    </summary>
                    <div class="rule-card-body">
                        <p class="rule-original">{{ rule.definition }}</p>
                        <p class="rule-translation">{{ rule.translation }}</p>
                        <details class="rule-impl-toggle">
                            <summary>Implementation</summary>
                            <pre class="rule-code">{{ rule.implementation }}</pre>
                        </details>
                    </div>
                </details>
            {% else %}
                <p style="color:var(--muted);font-size:0.85rem">No rules found. Run <code>php bin/console app:seed-voice-leading-rules</code> to seed the database.</p>
            {% endfor %}
            </div>
        </div>
    </details>

</div><!-- .wrapper -->

<!-- Chord Inspector Modal -->
<div id="chord-inspector" class="ci-overlay" role="dialog" aria-modal="true" aria-labelledby="ci-title-text">
    <div class="ci-panel">
        <div class="ci-header">
            <div class="ci-symbol" id="ci-symbol">?</div>
            <div class="ci-fig-stack" id="ci-fig-stack"></div>
            <div class="ci-header-text">
                <div class="ci-title" id="ci-title-text">{{ 'inspector.title'|trans }}</div>
                <div class="ci-subtitle" id="ci-subtitle"></div>
            </div>
            <button class="ci-edit-fig" id="ci-edit-fig" title="Edit figured bass" style="display:none">✎</button>
            <button class="ci-close" id="ci-close" aria-label="{{ 'inspector.close'|trans }}">✕</button>
        </div>

        <!-- Bass note grand staff (rendered by Verovio) -->
        <div class="ci-note-staff" id="ci-note-staff" style="display:none"></div>

        <!-- General information -->
        <div class="ci-section">
            <div class="ci-section-title">{{ 'inspector.section_info'|trans }}</div>
            <table class="ci-table" id="ci-info-table"></table>
        </div>

        <!-- Decision tree -->
        <div class="ci-section" id="ci-tree-section">
            <div class="ci-section-title">{{ 'inspector.section_tree'|trans }}</div>
            <div id="ci-source-badge-wrap"></div>
            <div class="ci-context" id="ci-context"></div>
            <div class="ci-steps" id="ci-steps"></div>
        </div>

        <!-- Figure editor (hidden until ✎ is clicked) -->
        <div class="ci-fig-editor" id="ci-fig-editor" style="display:none">
            <div class="ci-fig-editor-title">Edit Figured Bass</div>
            <div class="fig-hint">
                Figurato syntax: <code>65</code> = 6–5, <code>b7</code> = ♭7, <code>#4</code> = ♯4,
                <code>bb7</code> = 𝄫7, <code>n6</code> = ♮6. Clear the field to let the algorithm decide.
            </div>
            <input type="text" class="fig-input" id="ci-fig-input"
                   placeholder="e.g. 65 or b7 or #4 or empty"
                   autocomplete="off" spellcheck="false">
            <div class="fig-preview-row">
                <span class="fig-preview-label">Preview:</span>
                <span class="fig-preview" id="ci-fig-preview"></span>
            </div>
            <div class="fig-btn-row">
                <button class="fig-btn fig-btn-cancel" id="ci-fig-cancel">Cancel</button>
                <button class="fig-btn fig-btn-apply" id="ci-fig-apply">Apply &amp; Re-realize</button>
            </div>
        </div>
    </div>
</div>

<footer>
    <p>
        Basso Continuo Realizer &mdash; Based on
        <a href="https://quod.lib.umich.edu/i/icmc/bbp2372.2007.150" target="_blank" rel="noopener">Wead &amp; Knopke (ICMC 2007)</a>,
        Gasparini (1729) &amp; Delair (1724)
    </p>
</footer>

